<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="0dp"/>
            <gradient
                android:startColor="@color/tv_progressbar_bg"
                android:endColor="@color/tv_progressbar_bg"
                android:angle="270"
                android:centerY="0.75"/>
        </shape>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <corners android:radius="0dp"/>
                <gradient
                    android:startColor="@color/tv_secondary_progress_bg"
                    android:endColor="@color/tv_secondary_progress_bg"
                    android:angle="270"
                    android:centerY="0.75"/>
            </shape>
        </clip>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="0dp"/>
                <gradient
                    android:startColor="@color/tv_first_progress_bg"
                    android:endColor="@color/tv_first_progress_bg"
                    android:angle="270"
                    android:centerY="0.75"/>
            </shape>
        </clip>
    </item>
</layer-list>
