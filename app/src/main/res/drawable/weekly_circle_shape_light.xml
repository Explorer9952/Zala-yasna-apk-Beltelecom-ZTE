<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:shape="oval"
    android:useLevel="false"
    skin:enable="true">
    <solid
        android:color="@color/tv_date_circle_normalcolor"
        skin:enable="true"/>
    <stroke
        android:width="1.2dp"
        android:color="@color/tv_date_weekly_textcolor"/>
    <corners android:radius="360dp"/>
    <padding
        android:left="1.5dp"
        android:top="1.5dp"
        android:right="1.5dp"
        android:bottom="1.5dp"/>
    <size
        android:height="13dp"
        android:width="13dp"/>
</shape>
