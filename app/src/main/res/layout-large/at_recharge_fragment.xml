<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/mine_feedback_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/top"
        android:background="@color/mine_setting_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <include layout="@layout/common_header_level_two"/>
    <TextView
        android:textSize="14dp"
        android:textColor="@color/recharge_txt_bg"
        android:id="@+id/txt_voucher_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="40dp"
        android:layout_marginStart="20dp"/>
    <RelativeLayout
        android:id="@+id/rl_password"
        android:background="@color/login_input_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="7dp"
        android:layout_marginRight="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp">
        <EditText
            android:textSize="20dp"
            android:textColor="@color/login_input_textcolor"
            android:textColorHint="@color/login_inputhint_textcolor"
            android:id="@+id/edtLoginPassword"
            android:background="@color/login_input_bg"
            android:paddingLeft="10dp"
            android:paddingRight="40dp"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:singleLine="true"
            android:layout_toRightOf="@+id/img_pw_lock"
            android:textCursorDrawable="@drawable/edit_cusor_style"
            android:paddingStart="10dp"
            android:paddingEnd="40dp"
            android:layout_toEndOf="@+id/img_pw_lock"/>
        <ImageView
            android:id="@+id/img_password_clear"
            android:background="@drawable/input_clear_style"
            android:visibility="gone"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginRight="10dp"
            android:layout_alignRight="@+id/edtLoginPassword"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:layout_alignEnd="@+id/edtLoginPassword"/>
    </RelativeLayout>
    <Button
        android:textSize="17dp"
        android:textColor="@color/white"
        android:layout_gravity="center"
        android:id="@+id/btn_confirm"
        android:background="@drawable/confirm_bg"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="40dp"
        android:layout_marginRight="20dp"
        android:textAllCaps="false"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"/>
</LinearLayout>
