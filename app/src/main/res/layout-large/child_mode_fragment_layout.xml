<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_pad"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/top"
        android:background="@color/mine_setting_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <include layout="@layout/common_header_level_two"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ListView
            android:id="@+id/lst_level"
            android:paddingBottom="100dp"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/container_child_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@+id/lst_level"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp">
            <LinearLayout
                android:id="@+id/child_confirm_btn_layout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:layout_weight="1"
                android:layout_marginEnd="15dp">
                <Button
                    android:textSize="20dp"
                    android:textColor="@color/login_hint_textcolor"
                    android:layout_gravity="center"
                    android:id="@+id/btnconfirm"
                    android:background="@drawable/login_btn_disable"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="@string/common_ok"
                    android:textAllCaps="false"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/child_switch_btn_layout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:layout_weight="1"
                android:layout_marginStart="15dp">
                <Button
                    android:textSize="20dp"
                    android:textColor="@color/login_hint_textcolor"
                    android:layout_gravity="center"
                    android:id="@+id/btnSwitch"
                    android:background="@drawable/login_btn_disable"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="@string/switch_child_mode"
                    android:textAllCaps="false"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
