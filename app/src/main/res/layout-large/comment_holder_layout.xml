<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/iv_comment_head"
        android:background="@drawable/profile_userpic"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="10dp"/>
    <TextView
        android:textSize="14dp"
        android:textColor="@color/white"
        android:gravity="center_vertical"
        android:id="@+id/tv_comment_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="15dp"
        android:layout_toRightOf="@+id/iv_comment_head"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"/>
    <TextView
        android:textSize="12dp"
        android:textColor="@color/mine_hintwords_textcolor"
        android:id="@+id/comment_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:minHeight="20dp"
        android:layout_below="@+id/tv_comment_name"
        android:layout_alignLeft="@+id/tv_comment_name"
        android:layout_alignParentRight="true"/>
    <TextView
        android:textSize="16dp"
        android:textColor="@color/white"
        android:id="@+id/tv_comment_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="10dp"
        android:minHeight="20dp"
        android:layout_below="@+id/comment_time"
        android:layout_alignLeft="@+id/tv_comment_name"
        android:layout_alignParentRight="true"/>
    <ImageView
        android:id="@+id/del_comment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginRight="20dp"
        android:src="@drawable/icon_delete"
        android:layout_alignParentRight="true"/>
    <ImageView
        android:background="@color/video_separateline_color"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_below="@+id/tv_comment_content"/>
</RelativeLayout>
