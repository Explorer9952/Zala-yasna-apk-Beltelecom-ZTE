<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    skin:enable="true">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/llayout"
        android:background="@drawable/common_dialog_corner"
        android:layout_width="@dimen/pad_commont_dialog_width"
        android:layout_height="wrap_content"
        skin:enable="true">
        <TextView
            android:textSize="16dp"
            android:textColor="@color/dialog_text"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="15dp"
            android:adjustViewBounds="true"
            android:minHeight="120dp"
            android:layoutDirection="locale"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            skin:enable="true"/>
        <View
            android:id="@+id/customdialog_view1"
            android:background="#ffd8d8d8"
            android:layout_width="match_parent"
            android:layout_height="0.5px"/>
        <LinearLayout
            android:gravity="start"
            android:orientation="horizontal"
            android:id="@+id/customdialog_ll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:gravity="start"
                android:id="@+id/rl_button_cancel"
                android:background="@drawable/lock_dialog_leftbg"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                skin:enable="true">
                <TextView
                    android:textSize="18dp"
                    android:textColor="@color/dialog_btn_txt_bg"
                    android:gravity="center"
                    android:id="@+id/text_cancel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    skin:enable="true"/>
                <ImageView
                    android:gravity="start"
                    android:id="@+id/img_cancel_left"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="10dp"
                    android:layout_toStartOf="@+id/text_cancel"
                    skin:enable="true"/>
            </RelativeLayout>
            <View
                android:id="@+id/customdialog_view2"
                android:background="@color/dialog_devide"
                android:layout_width="0.5px"
                android:layout_height="match_parent"/>
            <RelativeLayout
                android:gravity="start"
                android:id="@+id/rl_button_ok"
                android:background="@drawable/lock_dialog_rightbg"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                skin:enable="true">
                <TextView
                    android:textSize="18dp"
                    android:textColor="@color/dialog_btn_txt_bg"
                    android:gravity="center"
                    android:id="@+id/text_ok"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    skin:enable="true"/>
                <ImageView
                    android:gravity="start"
                    android:id="@+id/img_ok_left"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="10dp"
                    android:layout_toStartOf="@+id/text_ok"
                    skin:enable="true"/>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
