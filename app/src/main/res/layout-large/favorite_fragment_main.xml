<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:background="@drawable/bg_pad"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        style="@style/top_bar"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/favorite_rlayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/top">
        <RelativeLayout
            android:id="@+id/title_rlayout"
            android:background="@color/mine_favorite_title_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mine_fragment_myaccount_ll_height"
            skin:enable="true">
            <Button
                android:id="@+id/btn_back"
                android:background="@drawable/title_back_bg"
                android:visibility="gone"
                android:layout_width="43dp"
                android:layout_height="52dp"
                android:layout_centerVertical="true"
                skin:enable="true"/>
            <TextView
                android:textSize="@dimen/title_textsize"
                android:textColor="@color/mine_favorite_title_textcolor"
                android:id="@+id/title_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                skin:enable="true"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/fav_edit_llayout"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true">
                <TextView
                    android:textSize="@dimen/common_16_px"
                    android:textColor="@color/mine_favorite_menu_textcolor"
                    android:id="@+id/edit_txt"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="15dp"
                    skin:enable="true"/>
                <ImageView
                    android:id="@+id/fav_edit_ivew"
                    android:background="@drawable/title_edit_style"
                    android:visibility="gone"
                    android:layout_width="43dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="15dp"/>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/edit_rlayout"
            android:background="@color/mine_favorite_titlebar_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mine_fragment_myaccount_ll_height"
            skin:enable="true">
            <TextView
                android:textSize="@dimen/common_16_px"
                android:textColor="@color/my_common_edit_or_select_all"
                android:id="@+id/txt_selected_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"
                skin:enable="true"/>
            <TextView
                android:textSize="@dimen/common_16_px"
                android:textColor="@color/mine_favorite_titlebar_textcolor"
                android:id="@+id/txt_selected_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                skin:enable="true"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/fav_cancel_edit_llayout"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true">
                <TextView
                    android:textSize="@dimen/common_16_px"
                    android:textColor="@color/my_common_edit_or_select_all"
                    android:id="@+id/txt_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="15dp"
                    skin:enable="true"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
    <ImageView
        android:id="@+id/title_bottom_line"
        android:background="@color/mine_favorite_separateline_bg"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_below="@+id/favorite_rlayout"
        android:contentDescription="@string/content_description"
        skin:enable="true"/>
    <com.scwang.smartrefresh.layout.SmartRefreshLayout
        android:id="@+id/refreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/title_bottom_line">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <include layout="@layout/empty_pull_refresh_view"/>
            <GridView
                android:gravity="fill"
                android:id="@+id/favorite_grid_view"
                android:background="@color/transparent"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:listSelector="@drawable/transparent"
                android:verticalSpacing="8dp"
                android:stretchMode="columnWidth"
                android:numColumns="6"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                skin:enable="true"/>
        </RelativeLayout>
    </com.scwang.smartrefresh.layout.SmartRefreshLayout>
    <FrameLayout
        android:id="@+id/fl_delete"
        android:background="@color/mine_favorite_delete_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_alignParentBottom="true"
        skin:enable="true">
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/ll_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img_delete"
                android:background="@drawable/myfav_action_delete"
                android:layout_width="23dp"
                android:layout_height="23dp"
                skin:enable="true"/>
            <TextView
                android:textSize="20sp"
                android:textColor="@color/mine_favorite_delete_textcolor"
                android:layout_gravity="center_vertical"
                android:id="@+id/txt_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp"
                skin:enable="true"/>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>
