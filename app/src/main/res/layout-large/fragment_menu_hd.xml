<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/ll_root"
    android:background="@drawable/bg_pad"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <RelativeLayout
        android:id="@+id/top_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/top"
            android:background="@color/transparent"
            style="@style/top_bar"
            skin:enable="true"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_my_account"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mine_fragment_myaccount_ll_height"
            android:layout_below="@+id/top"
            skin:enable="true">
            <ImageView
                android:id="@+id/top_navbar_logo_img"
                android:visibility="gone"
                android:layout_width="@dimen/my_top_navbar_logo_width"
                android:layout_height="@dimen/my_top_navbar_logo_height"
                android:src="@drawable/logo_top"
                android:scaleType="fitXY"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/my_top_navbar_logo_margin_start"
                android:layout_alignParentStart="true"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true">
            <ImageView
                android:id="@+id/iv_mine_account_icon"
                android:background="@drawable/mine_account_icon"
                android:layout_width="@dimen/my_account_icon_width"
                android:layout_height="@dimen/my_account_icon_height"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/my_top_navbar_logo_margin_start"
                skin:enable="true"/>
            <TextView
                android:textSize="20dp"
                android:textColor="@color/mine_username_textcolor"
                android:ellipsize="end"
                android:id="@+id/tv_mine_account_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="false"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                skin:enable="true"/>
        </LinearLayout>
    </RelativeLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_menu"
        android:background="@color/transparent"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
