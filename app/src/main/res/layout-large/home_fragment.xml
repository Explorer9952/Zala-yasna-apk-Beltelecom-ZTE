<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/ll_home_page"
    android:background="@drawable/bg_phone"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/top"
        android:background="@color/transparent"
        style="@style/top_bar"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/ll_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_navbar_logo_and_search_total_height">
        <FrameLayout
            android:id="@+id/frame_top_navbar"
            android:layout_width="@dimen/top_navbar_search_layout_width"
            android:layout_height="@dimen/top_navbar_search_layout_height"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textSize="@dimen/search_default_txt_textsize"
            android:textColor="@color/home_topnavbar_moresearch_textcolor"
            android:gravity="center"
            android:id="@+id/tv_child_entrance"
            android:background="@drawable/home_child_entrance_bg"
            android:paddingLeft="30dp"
            android:paddingRight="30dp"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/top_navbar_search_height"
            android:layout_marginRight="10dp"
            android:text="@string/child_club"
            android:layout_toLeftOf="@+id/frame_top_navbar"
            android:layout_centerVertical="true"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:layout_marginEnd="10dp"/>
        <TextView
            android:textSize="@dimen/top_navbar_title_textsize"
            android:textColor="@color/home_topnavbar_moresearch_textcolor"
            android:gravity="center"
            android:id="@+id/top_navbar_title_txt"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:maxLines="1"
            android:layout_marginStart="@dimen/top_navbar_logo_margin_start"
            android:layout_toStartOf="@+id/tv_child_entrance"
            android:layout_alignParentStart="true"/>
    </RelativeLayout>
    <FrameLayout
        android:id="@+id/home_viewpager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>
