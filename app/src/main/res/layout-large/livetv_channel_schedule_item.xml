<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/ll_schedule_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_program_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/ll_now_playing"
            android:visibility="gone"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textSize="16dp"
                android:textColor="@color/tv_prevue_now_textcolor"
                android:gravity="end"
                android:layout_gravity="center"
                android:id="@+id/txt_playing"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                skin:enable="true"/>
            <pl.droidsonroids.gif.GifImageView
                android:layout_gravity="center"
                android:id="@+id/img_playing"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/channellist_playing"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"/>
        </LinearLayout>
        <RelativeLayout
            android:id="@+id/rl_play_state"
            android:visibility="visible"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ll_now_playing"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/img_play"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/tv_tvod_play_bg"
                android:layout_centerHorizontal="true"/>
            <TextView
                android:textSize="16dp"
                android:gravity="center"
                android:id="@+id/txt_play"
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:text="@string/tv_program_nowplaying"
                android:layout_below="@+id/img_play"
                android:layout_centerHorizontal="true"/>
        </RelativeLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_program_describ"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_showdetail"
                android:layout_width="430dp"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:textSize="14dp"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:id="@+id/txt_program_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:id="@+id/playnow"
                        android:background="@drawable/tv_playnow_bg"
                        android:paddingLeft="3dp"
                        android:paddingRight="3dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:text="@string/now"/>
                </LinearLayout>
                <TextView
                    android:textSize="15dp"
                    android:gravity="center_vertical"
                    android:id="@+id/txt_program_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <RelativeLayout
        android:id="@+id/rl_progressbar"
        android:layout_width="match_parent"
        android:layout_height="4dp">
        <ProgressBar
            android:id="@+id/pb_playing_light"
            android:visibility="visible"
            android:clickable="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:max="100"
            android:progress="0"
            style="@style/StyleProgressBarMiniLight"/>
        <ProgressBar
            android:id="@+id/pb_playing_dark"
            android:visibility="gone"
            android:clickable="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:max="100"
            android:progress="0"
            style="@style/StyleProgressBarMiniDark"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_description"
        android:background="@color/tv_functionmenu_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <View
            android:background="@color/common_separateline_color"
            android:layout_width="match_parent"
            android:layout_height="0.1px"/>
        <RelativeLayout
            android:id="@+id/rl_tv_channel_schedule_recording"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <ImageView
                android:id="@+id/img_tv_channel_schedule_recording"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginLeft="15dp"
                android:layout_alignParentLeft="true"/>
            <RelativeLayout
                android:gravity="center"
                android:id="@+id/rl_arrow"
                android:layout_width="66dp"
                android:layout_height="18dp"
                android:layout_alignParentRight="true">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/livetv_arrow"/>
            </RelativeLayout>
        </RelativeLayout>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/multiplayer_prevuename_now_light"
            android:id="@+id/tvt_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="13dp"
            android:layout_marginBottom="12dp"/>
    </LinearLayout>
    <View
        android:id="@+id/divider_line"
        android:layout_width="match_parent"
        android:layout_height="0.5px"/>
</LinearLayout>
