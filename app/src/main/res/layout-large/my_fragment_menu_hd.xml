<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/ll_root"
    android:background="@drawable/bg_pad"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <RelativeLayout
        android:id="@+id/top_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/top"
            android:background="@color/transparent"
            style="@style/top_bar"
            skin:enable="true"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_my_account"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mine_fragment_myaccount_ll_height"
            android:layout_below="@+id/top"
            skin:enable="true">
            <TextView
                android:textSize="20dp"
                android:textColor="@color/mine_username_textcolor"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/tv_mine_account_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/my_txt"
                android:singleLine="false"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                skin:enable="true"/>
        </LinearLayout>
    </RelativeLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/my_recycler_menu"
        android:background="@color/transparent"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
