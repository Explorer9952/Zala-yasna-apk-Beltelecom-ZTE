<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/rl_order_dialog"
        android:background="@drawable/order_dialog_bg"
        android:layout_width="@dimen/pad_commont_dialog_width"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="16dp"
            android:textColor="@color/white"
            android:id="@+id/title"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="12dp"
            android:text="@string/confirm_order"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/white"
            android:id="@+id/pacakge_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:text="@string/valid_time"
            android:layout_below="@+id/title"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/white"
            android:id="@+id/rentalterm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/valid_time"
            android:layout_below="@+id/pacakge_name"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/white"
            android:id="@+id/price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/video_detail_title_price"
            android:layout_below="@+id/rentalterm"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/series_detail_info_light"
            android:id="@+id/tips"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:text="@string/enter_orderpwd_check"
            android:layout_below="@+id/price"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"/>
        <EditText
            android:textSize="11dp"
            android:textColor="@color/order_txt_bg"
            android:textColorHint="@color/dialog_order_et_bg"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/parental_password"
            android:background="@drawable/order_edit_background"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="15dp"
            android:hint="@string/input_limpwd"
            android:layout_below="@+id/tips"
            android:layout_centerInParent="true"
            android:inputType="textPassword"
            android:imeOptions="flagNoExtractUi"
            android:textCursorDrawable="@drawable/lock_edit_input_style"
            android:paddingStart="5dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            skin:enable="true"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/white"
            android:id="@+id/txtvew_show_tips"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/limitpwd_is_wrong"
            android:layout_below="@+id/parental_password"
            android:layout_marginStart="28dp"
            skin:enable="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/comm_dialog_bottom"
        android:layout_width="@dimen/pad_commont_dialog_width"
        android:layout_height="50dp"
        android:layout_below="@+id/rl_order_dialog">
        <TextView
            android:textSize="18dp"
            android:textColor="@color/order_txt_bg"
            android:gravity="center"
            android:id="@+id/buy"
            android:background="@drawable/order_dialog_bottonleft_bg"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/rent"
            android:layout_weight="1"
            skin:enable="true"/>
        <View
            android:background="@color/dialog_devide"
            android:layout_width="1dp"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="18dp"
            android:textColor="@color/order_txt_bg"
            android:gravity="center"
            android:id="@+id/cancel"
            android:background="@drawable/order_dialog_bottonright_background"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/cancel_order"
            android:layout_weight="1"
            skin:enable="true"/>
    </LinearLayout>
</RelativeLayout>
