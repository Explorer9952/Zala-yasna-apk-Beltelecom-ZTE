<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:id="@+id/rl_privacy_dialog"
    android:background="@drawable/order_dialog_bg"
    android:layout_width="@dimen/pad_commont_dialog_width"
    android:layout_height="wrap_content"
    android:layout_centerHorizontal="true">
    <ScrollView
        android:id="@+id/sc_privacy"
        android:layout_width="wrap_content"
        android:layout_height="300dp"
        android:layout_below="@+id/title">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16dp"
                android:textColor="@color/white"
                android:id="@+id/txt_privacy_one"
                android:paddingTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/privacy_txt_one"
                android:lineSpacingExtra="2dp"
                android:paddingStart="30dp"
                android:paddingEnd="30dp"/>
            <TextView
                android:textSize="16dp"
                android:textColor="@color/white"
                android:id="@+id/txt_privacy_two"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/privacy_txt_two"
                android:lineSpacingExtra="2dp"
                android:paddingStart="30dp"
                android:paddingEnd="30dp"/>
        </LinearLayout>
    </ScrollView>
    <TextView
        android:textSize="18dp"
        android:textColor="@color/order_txt_bg"
        android:gravity="center"
        android:id="@+id/agree"
        android:background="@drawable/privacy_dialog_botton_background"
        android:layout_width="@dimen/pad_commont_dialog_width"
        android:layout_height="50dp"
        android:text="@string/agree"
        android:layout_below="@+id/sc_privacy"
        skin:enable="true"/>
    <TextView
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/title"
        android:paddingTop="20dp"
        android:paddingBottom="7dp"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_privacy"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"/>
</RelativeLayout>
