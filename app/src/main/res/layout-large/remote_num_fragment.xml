<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:paddingBottom="30dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/fl_num_show"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <TextView
            android:textSize="60dp"
            android:textColor="@color/remote_numbershow_textcolor"
            android:layout_gravity="center"
            android:id="@+id/txt_num_show"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            skin:enable="true"/>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_num"
        android:paddingTop="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="50dp"
        android:paddingEnd="50dp"
        skin:enable="true">
        <RelativeLayout
            android:id="@+id/rl_remote_nums1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="130dp"
            android:layout_marginRight="130dp"
            android:layout_marginBottom="20dp">
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num1"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                skin:enable="true"/>
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num2"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_centerHorizontal="true"
                skin:enable="true"/>
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num3"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_remote_nums2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="130dp"
            android:layout_marginRight="130dp"
            android:layout_marginBottom="20dp">
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num4"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                skin:enable="true"/>
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num5"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_centerHorizontal="true"
                skin:enable="true"/>
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num6"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_remote_nums3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="130dp"
            android:layout_marginRight="130dp"
            android:layout_marginBottom="20dp">
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num7"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                skin:enable="true"/>
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num8"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_centerHorizontal="true"
                skin:enable="true"/>
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num9"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="130dp"
            android:layout_marginRight="130dp">
            <ImageView
                android:id="@+id/num_dot"
                android:background="@drawable/remote_btn_num_dot_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                skin:enable="true"/>
            <TextView
                android:textSize="40dp"
                android:textColor="@drawable/remote_btn_num_txt_style"
                android:gravity="center"
                android:id="@+id/num0"
                android:background="@drawable/remote_btn_num_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_centerHorizontal="true"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/num_del"
                android:background="@drawable/remote_btn_num_del_bg"
                android:layout_width="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_height="@dimen/pad_remote_btn_round_height_width_pad"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
