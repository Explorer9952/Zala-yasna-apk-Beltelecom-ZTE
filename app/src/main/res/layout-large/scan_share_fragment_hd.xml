<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_pad"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <TextView
        android:textSize="@dimen/title_textsize"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/share_title"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:text="@string/share_title"
        android:layout_weight="1"/>
    <TextView
        android:background="@color/video_separateline_color"
        android:layout_width="match_parent"
        android:layout_height="2dp"/>
    <RelativeLayout
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:layout_weight="5">
        <ImageView
            android:id="@+id/image_stb_pic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/stb_pic"
            android:scaleType="fitCenter"/>
    </RelativeLayout>
    <RelativeLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_weight="4">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true">
            <TextView
                android:textSize="15dp"
                android:textColor="@color/binding_scanbutton_bg"
                android:id="@+id/scan_share_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/scan_share_text"/>
            <LinearLayout
                android:id="@+id/scan_share_step1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_below="@+id/scan_share_text"
                android:layout_alignLeft="@+id/scan_share_text">
                <TextView
                    android:textSize="15dp"
                    android:textColor="@color/binding_scanbutton_bg"
                    android:id="@+id/txt_step_one"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="@string/scan_share_stepOne"
                    android:layout_weight="1"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/scan_share_step2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_below="@+id/scan_share_step1"
                android:layout_alignLeft="@+id/scan_share_text">
                <TextView
                    android:textSize="15dp"
                    android:textColor="@color/binding_scanbutton_bg"
                    android:id="@+id/txt_step_two"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="@string/scan_share_stepTwo"
                    android:layout_weight="1"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/scan_share_step3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_below="@+id/scan_share_step2"
                android:layout_alignLeft="@+id/scan_share_text">
                <TextView
                    android:textSize="15dp"
                    android:textColor="@color/binding_scanbutton_bg"
                    android:id="@+id/txt_step_thr"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="@string/scan_share_stepThr"
                    android:layout_weight="1"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
    <LinearLayout
        android:id="@+id/scan_share_btn"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <include layout="@layout/scan_share_layout"/>
    </LinearLayout>
</LinearLayout>
