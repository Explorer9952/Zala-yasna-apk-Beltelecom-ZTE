<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/search_layout"
    android:background="@drawable/bg_pad"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_pad"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:id="@+id/top"
            android:background="@color/search_status_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            skin:enable="true"/>
        <include
            android:layout_height="wrap_content"
            layout="@layout/header_search_back"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="15dp"
            skin:enable="true"/>
        <View
            android:background="@color/search_column_text_deselected"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            skin:enable="true"/>
        <include layout="@layout/rl_search_layout"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_multiscreen_program_edit_view"
            android:paddingRight="2dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="1dp"
            android:layout_alignParentBottom="true"
            android:paddingEnd="2dp">
            <View
                android:id="@+id/multiscreen_program_edit_view_top"
                android:background="@color/search_separate_bg"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                skin:enable="true"/>
            <include layout="@layout/multiscreen_program_edit"/>
            <View
                android:id="@+id/multiscreen_program_edit_view_buttom"
                android:background="@color/search_separate_bg"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                skin:enable="true"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
