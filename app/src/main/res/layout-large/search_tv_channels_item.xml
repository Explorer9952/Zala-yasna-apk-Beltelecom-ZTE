<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_channel_item"
            android:paddingLeft="11dp"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:paddingStart="11dp">
            <RelativeLayout
                android:layout_gravity="center_vertical"
                android:background="@color/channel_sort_bg"
                android:layout_width="@dimen/search_tv_icon_pad_width"
                android:layout_height="@dimen/search_tv_icon_pad_height">
                <ImageView
                    android:id="@+id/img_channel_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/default_video_thumb"
                    android:scaleType="fitCenter"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:id="@+id/ll_channel_item_describ"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp">
                <TextView
                    android:textSize="16dp"
                    android:textColor="@color/vod_programname_textcolor"
                    android:id="@+id/txt_channel_current_program_name"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    skin:enable="true"/>
                <TextView
                    android:textSize="16dp"
                    android:textColor="@color/mine_hintwords_textcolor"
                    android:id="@+id/txt_channel_current_program_duration"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    skin:enable="true"/>
                <TextView
                    android:textSize="16dp"
                    android:textColor="@color/mine_hintwords_textcolor"
                    android:id="@+id/txt_channel_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:singleLine="true"
                    skin:enable="true"/>
            </LinearLayout>
        </LinearLayout>
        <RelativeLayout
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/rl_fav"
            android:layout_width="120dp"
            android:layout_height="100dp"
            android:layout_marginRight="15dp">
            <LinearLayout
                android:id="@+id/rl_fav_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/img_channel_fav"
                    android:layout_width="26dp"
                    android:layout_height="27dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/img_channel_layout"
                android:visibility="gone"
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:layout_marginRight="25dp"
                android:layout_toLeftOf="@+id/rl_fav_layout"
                android:layout_marginEnd="25dp"
                android:layout_toStartOf="@+id/rl_fav_layout">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/img_channel_detail"
                    android:layout_width="25dp"
                    android:layout_height="23dp"
                    android:src="@drawable/tv_info_icon"
                    skin:enable="true"/>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
    <View
        android:background="@color/search_history_tab_bg"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
</LinearLayout>
