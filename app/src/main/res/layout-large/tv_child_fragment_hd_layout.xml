<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@drawable/bg_child"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/ll_nav_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:gravity="center"
            android:id="@+id/rl_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_navbar_logo_and_search_total_height">
            <TextView
                android:textSize="@dimen/top_navbar_title_textsize"
                android:textColor="@color/home_topnavbar_moresearch_textcolor"
                android:gravity="center"
                android:id="@+id/top_navbar_title_txt"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:maxLines="1"
                android:layout_marginStart="@dimen/top_navbar_logo_margin_start"
                android:layout_toStartOf="@+id/frame_top_navbar"/>
        </RelativeLayout>
        <ImageView
            android:id="@+id/title_bottom_line"
            android:background="@color/mine_favorite_separateline_bg"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_below="@+id/rl_bar"
            skin:enable="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/rl_tv_main_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.8">
                <View
                    android:id="@+id/viewleft"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.25"/>
                <FrameLayout
                    android:id="@+id/tv_play_base_container"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.5"/>
                <View
                    android:id="@+id/viewright"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.25"/>
            </LinearLayout>
            <FrameLayout
                android:id="@+id/tv_channel_list_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="51dp"
                android:layout_weight="1"
                android:layout_alignParentStart="true"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
