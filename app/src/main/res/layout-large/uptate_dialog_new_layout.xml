<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/rl_update_view_all_layout"
        android:background="@drawable/common_dialog_corner"
        android:layout_width="@dimen/pad_commont_dialog_width"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/image"
            android:background="@drawable/popup_update"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"/>
        <TextView
            android:textSize="18dp"
            android:textColor="@color/white"
            android:gravity="center_horizontal"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp"
            android:layout_below="@+id/image"
            android:layout_centerHorizontal="true"
            android:lineSpacingExtra="5dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>
        <TextView
            android:textSize="18dp"
            android:textColor="@color/white"
            android:gravity="center_horizontal"
            android:id="@+id/message"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:minHeight="70dp"
            android:layout_below="@+id/tv_title"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>
        <RelativeLayout
            android:id="@+id/rl_button_ok"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_below="@+id/message">
            <View
                android:background="@color/dialog_devide"
                android:layout_width="match_parent"
                android:layout_height="1px"/>
            <TextView
                android:textSize="18dp"
                android:textColor="@color/dialog_btn_txt_bg"
                android:id="@+id/text_ok"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"/>
            <ImageView
                android:id="@+id/img_ok_left"
                android:background="@drawable/ic_launcher"
                android:visibility="gone"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_centerVertical="true"
                android:layout_marginEnd="20dp"
                android:layout_toStartOf="@+id/text_ok"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_button_cancel"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_below="@+id/rl_button_ok">
            <View
                android:background="@color/dialog_devide"
                android:layout_width="match_parent"
                android:layout_height="1px"/>
            <TextView
                android:textSize="18dp"
                android:textColor="@color/dialog_btn_txt_bg"
                android:id="@+id/text_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"/>
            <ImageView
                android:id="@+id/img_cancel_left"
                android:background="@drawable/ic_launcher"
                android:visibility="gone"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_centerVertical="true"
                android:layout_marginEnd="20dp"
                android:layout_toStartOf="@+id/text_cancel"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/progreesLayout"
            android:background="@color/white"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="223dp"
            android:layout_below="@+id/image">
            <com.zte.iptvclient.android.common.customview.view.RoundProgressBar
                android:id="@+id/roundProgress"
                android:layout_width="93dp"
                android:layout_height="93dp"
                android:layout_marginTop="33dp"
                android:layout_centerHorizontal="true"
                app:roundProgressColor="@color/anhui_mobile_theme"
                app:roundWidth="7dp"
                app:textColor="@color/alert_title_color"
                app:textSize="20sp"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/alert_title_color"
                android:id="@+id/roundProgress_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_below="@+id/roundProgress"
                android:layout_centerHorizontal="true"/>
            <RelativeLayout
                android:id="@+id/btn_oks_layout"
                android:visibility="invisible"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_alignParentBottom="true">
                <LinearLayout
                    android:background="@color/update_dialog_line"
                    android:layout_width="match_parent"
                    android:layout_height="1px"/>
                <TextView
                    android:textSize="20dp"
                    android:textColor="@color/anhui_mobile_theme"
                    android:id="@+id/tv_install"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>
