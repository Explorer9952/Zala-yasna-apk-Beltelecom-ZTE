<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/ll_video_item"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_img"
        android:layout_width="110dp"
        android:layout_height="158dp">
        <ImageView
            android:id="@+id/poster_img"
            android:background="@drawable/default_poster_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/img_corner"
            android:visibility="gone"
            android:layout_width="@dimen/corner_width"
            android:layout_height="@dimen/corner_height"
            android:layout_alignParentTop="true"
            android:layout_alignParentRight="true"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/ivi_logo_top"
            android:visibility="gone"
            android:layout_width="27.2dp"
            android:layout_height="20dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/ivi_logo"
            android:layout_alignParentRight="true"
            android:layout_marginEnd="5dp"/>
        <RelativeLayout
            android:id="@+id/rating_rl"
            android:background="@color/gallery_title_bg_color"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_alignParentBottom="true"
            skin:enable="true">
            <TextView
                android:textSize="@dimen/common_title_bar_textsize"
                android:textColor="@color/download_play_all_bar_color"
                android:id="@+id/rating_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_del_select"
            android:background="@color/delete_select_bg_color"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            skin:enable="true">
            <ImageView
                android:id="@+id/img_del_select"
                android:background="@drawable/icon_item_select"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_centerInParent="true"
                skin:enable="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_del_selected"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            skin:enable="true">
            <ImageView
                android:id="@+id/img_del_selected1"
                android:background="@drawable/icon_profile_select"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_centerInParent="true"
                skin:enable="true"/>
        </RelativeLayout>
    </RelativeLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/vod_programname_textcolor"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:layout_gravity="center_vertical"
        android:id="@+id/title_txt"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:singleLine="true"
        skin:enable="true"/>
</LinearLayout>
