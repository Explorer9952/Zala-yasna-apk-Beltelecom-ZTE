<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/step_one_layout"
        android:background="@drawable/dialog_activity_bg"
        android:layout_width="310dp"
        android:layout_height="230dp"
        android:layout_centerInParent="true">
        <ImageView
            android:layout_gravity="end"
            android:id="@+id/btn_close"
            android:background="@drawable/channel_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginRight="15dp"
            android:layout_marginEnd="15dp"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/black_old"
            android:layout_gravity="start"
            android:id="@+id/common_confirm_dlg_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginStart="20dp"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="7dp"
            android:layout_marginRight="15dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginRight="4dp"
                android:layout_toLeftOf="@+id/btn_get_validate"
                android:layout_marginEnd="4dp"
                android:layout_toStartOf="@+id/btn_get_validate">
                <EditText
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:layout_gravity="start"
                    android:id="@+id/et_phone_num"
                    android:background="@drawable/paly_edit_bg"
                    android:paddingLeft="5dp"
                    android:focusable="false"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:paddingStart="5dp"/>
                <Button
                    android:id="@+id/btn_edittext_clear"
                    android:background="@drawable/btn_close"
                    android:visibility="gone"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_marginRight="5dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="5dp"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <Button
                android:textColor="@color/getvalidate_text_btn_selector"
                android:id="@+id/btn_get_validate"
                android:background="@drawable/bg_getvalidate_btn_selector"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_alignParentRight="true"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <EditText
            android:textSize="14sp"
            android:textColor="#000000"
            android:textColorHint="@color/home_column_title_erji"
            android:layout_gravity="start"
            android:id="@+id/et_auth_code"
            android:background="@drawable/paly_edit_bg"
            android:paddingLeft="5dp"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="15dp"
            android:inputType="number"
            android:paddingStart="5dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"/>
        <Button
            android:enabled="false"
            android:textColor="@color/white"
            android:id="@+id/btn_start_order"
            android:background="@drawable/bg_order_btn_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="25dp"
            android:layout_marginRight="15dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/step_two_layout"
        android:background="@drawable/dialog_activity_bg"
        android:visibility="gone"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textColor="#000000"
            android:id="@+id/txt_paying"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/step_three_layout"
        android:visibility="gone"
        android:layout_width="310dp"
        android:layout_height="260dp"
        android:layout_centerInParent="true">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center"
                android:id="@+id/ll_play_head"
                android:background="@drawable/pop_vip_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/order_result_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/icon_vip_success"/>
            </LinearLayout>
            <RelativeLayout
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/btn_order_final"
                android:layout_below="@+id/ll_play_head">
                <View
                    android:background="@color/all_line_bg_old"
                    android:layout_width="1px"
                    android:layout_height="match_parent"/>
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:textSize="20sp"
                        android:textColor="#000000"
                        android:id="@+id/tv_order_result_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"/>
                    <TextView
                        android:textColor="#000000"
                        android:id="@+id/tv_order_result_desc1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"/>
                    <TextView
                        android:textColor="#000000"
                        android:id="@+id/tv_order_result_desc2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
                <View
                    android:background="@color/all_line_bg_old"
                    android:layout_width="1px"
                    android:layout_height="match_parent"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <Button
                android:textColor="@color/black_old"
                android:id="@+id/btn_order_final"
                android:background="@drawable/play_btn_bg2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_alignParentStart="true"/>
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>
