<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="71dp"
    skin:enable="true">
    <RelativeLayout
        android:id="@+id/rl_plugin_icon"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_centerVertical="true">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/channel_sort_channel_name"
            android:id="@+id/txt_mixno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_centerVertical="true"/>
        <RelativeLayout
            android:id="@+id/dl_plugin_icon_container"
            android:background="@color/channel_sort_bg"
            android:layout_width="@dimen/lock_tv_icon_width"
            android:layout_height="@dimen/lock_tv_icon_height"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@+id/txt_mixno">
            <ImageView
                android:id="@+id/dl_plugin_icon"
                android:layout_width="@dimen/lock_tv_icon_width"
                android:layout_height="@dimen/lock_tv_icon_height"
                android:scaleType="fitCenter"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="17sp"
            android:textColor="@color/channel_sort_channel_name"
            android:ellipsize="end"
            android:id="@+id/dl_plugin_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"
            android:layout_toStartOf="@+id/dl_plugin_move"
            android:layout_toEndOf="@+id/dl_plugin_icon_container"/>
        <RelativeLayout
            android:id="@+id/dl_plugin_move"
            android:layout_width="65dp"
            android:layout_height="71dp"
            android:layout_marginEnd="20dp"
            android:layout_alignParentEnd="true">
            <ImageView
                android:id="@+id/dl_plugin_img"
                android:background="@drawable/edit_logo"
                android:layout_width="27dp"
                android:layout_height="27dp"
                android:layout_marginRight="17dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </RelativeLayout>
    <View
        android:background="@color/mine_favorite_separateline_bg"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
