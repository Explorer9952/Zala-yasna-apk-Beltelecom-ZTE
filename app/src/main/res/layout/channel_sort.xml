<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/channel_sort_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/channel_sort_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/actions_bar"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:layout_marginBottom="7dp"
        android:layout_below="@+id/top"
        skin:enable="true">
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/rl_colse_img"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_marginRight="6dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="6dp">
            <ImageView
                android:id="@+id/img_close"
                android:background="@drawable/title_back_bg"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                skin:enable="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/channel_sort_title_textcolor"
            android:id="@+id/title_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            skin:enable="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/detail_control"
        android:background="@color/channel_sort_control_bg"
        android:layout_width="match_parent"
        android:layout_height="27dp"
        android:layout_below="@+id/actions_bar"
        skin:enable="true">
        <TextView
            android:textSize="13sp"
            android:textColor="@color/channel_sort_control_textcolor"
            android:id="@+id/detail_tips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="13dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="13dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
    </RelativeLayout>
    <com.zte.iptvclient.android.mobile.tv.ui.DragListView
        android:id="@+id/draglist"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@color/channel_sort_divide_bg"
        android:dividerHeight="1dp"
        android:layout_below="@+id/detail_control"
        skin:enable="true"/>
</RelativeLayout>
