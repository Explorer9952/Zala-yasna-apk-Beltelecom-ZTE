<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:layout_gravity="center"
    android:id="@+id/common_confirm_dlg_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/common_confirm_dlg_llayout"
        android:background="@drawable/order_dialog_connent_bg"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="10dp"
        android:layout_centerHorizontal="true"
        skin:enable="true">
        <TextView
            android:textSize="18sp"
            android:textColor="@color/home_recommend_title_textcolor"
            android:layout_gravity="center_horizontal"
            android:id="@+id/common_confirm_dlg_title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            skin:enable="true"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/home_recommend_title_textcolor"
            android:layout_gravity="center_horizontal"
            android:id="@+id/common_confirm_dlg_content"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            skin:enable="true"/>
    </LinearLayout>
    <View
        android:id="@+id/botoom_line"
        android:background="@color/channel_sort_dialog_bg"
        android:layout_width="280dp"
        android:layout_height="10dp"
        android:layout_marginTop="-12dp"
        android:layout_below="@+id/common_confirm_dlg_llayout"
        android:layout_centerHorizontal="true"
        skin:enable="true"/>
    <LinearLayout
        android:orientation="horizontal"
        android:background="@drawable/order_dialog_buttom_bg"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/botoom_line"
        android:layout_centerHorizontal="true">
        <Button
            android:textSize="15dp"
            android:textColor="@color/black_old"
            android:gravity="center"
            android:id="@+id/more_logout_dialog_ok"
            android:background="@drawable/order_dialog_btn_bg"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            skin:enable="true"/>
        <Button
            android:textSize="15dp"
            android:textColor="@color/black_old"
            android:gravity="center"
            android:id="@+id/more_logout_dialog_cancel"
            android:background="@drawable/order_dialog_btn_bg"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            skin:enable="true"/>
    </LinearLayout>
</RelativeLayout>
