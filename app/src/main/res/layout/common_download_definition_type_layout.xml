<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/movie_download_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    skin:enable="true">
    <RelativeLayout
        android:id="@+id/rl_download_definition_title"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/download_definition_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="5dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="5dp"/>
        <ImageView
            android:id="@+id/arrow_definition"
            android:layout_width="16dp"
            android:layout_height="18dp"
            android:layout_toRightOf="@+id/download_definition_layout"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@+id/download_definition_layout"/>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/rl_colse_img"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true">
            <ImageView
                android:id="@+id/back_close"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/img_close_style"
                android:layout_centerInParent="true"
                skin:enable="true"/>
        </RelativeLayout>
    </RelativeLayout>
</LinearLayout>
