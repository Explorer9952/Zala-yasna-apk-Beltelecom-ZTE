<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:id="@+id/title_rlayout"
    android:background="@color/home_top_status_bg"
    android:layout_width="match_parent"
    android:layout_height="@dimen/mine_fragment_myaccount_ll_height"
    skin:enable="true">
    <Button
        android:gravity="center_vertical"
        android:id="@+id/btn_back"
        android:background="@drawable/title_back_bg"
        android:visibility="gone"
        android:layout_width="43dp"
        android:layout_height="52dp"
        android:layout_centerVertical="true"
        skin:enable="true"/>
    <TextView
        android:textSize="@dimen/title_textsize"
        android:textColor="@color/video_more_title_textcolor"
        android:id="@+id/title_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/header_bottom_line"
        android:background="@color/video_separateline_color"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_alignParentBottom="true"
        skin:enable="true"/>
</RelativeLayout>
