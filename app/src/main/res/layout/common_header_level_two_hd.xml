<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:id="@+id/title_rlayout"
    android:layout_width="match_parent"
    android:layout_height="45dp"
    skin:enable="true">
    <TextView
        android:textSize="@dimen/title_textsize"
        android:textColor="@color/video_more_title_textcolor"
        android:id="@+id/title_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_centerVertical="true"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/btn_back"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:layout_marginRight="6dp"
        android:layout_alignParentRight="true"
        android:layout_marginEnd="6dp"
        android:layout_alignParentEnd="true">
        <ImageView
            android:id="@+id/img_close"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/img_close_style"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/header_bottom_line"
        android:background="@color/video_separateline_color"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_alignParentBottom="true"
        skin:enable="true"/>
</RelativeLayout>
