<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@+id/top_txt_below_edit_layout"
    android:layout_width="390dp"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="16dp"
        android:textColor="@color/login_normal_txt"
        android:id="@+id/top_txt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>
    <RelativeLayout
        android:id="@+id/rl_edit"
        android:background="@drawable/at_login_edit_shape_bg"
        android:layout_width="match_parent"
        android:layout_height="48dp">
        <EditText
            android:textSize="16dp"
            android:textColor="@color/login_input_textcolor"
            android:textColorHint="@color/profile_login_textcolor_et_bg"
            android:id="@+id/below_edit"
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:textCursorDrawable="@drawable/edit_cusor_style"
            android:textAlignment="viewStart"
            android:paddingStart="8dp"
            android:layout_marginStart="3dp"/>
        <ImageView
            android:id="@+id/img_edit_clear"
            android:background="@drawable/input_clear_style"
            android:visibility="gone"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="16dp"
        android:textColor="@color/login_verification_textcolor"
        android:ellipsize="end"
        android:id="@+id/below_tip_txt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"/>
</LinearLayout>
