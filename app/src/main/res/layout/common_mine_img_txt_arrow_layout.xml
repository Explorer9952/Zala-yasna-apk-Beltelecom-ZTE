<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/common_img_txt_arrow_continer"
    android:layout_width="match_parent"
    android:layout_height="70dp">
    <ImageView
        android:id="@+id/iv_mine_left"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="25dp"
        android:layout_alignParentStart="true"/>
    <TextView
        android:textSize="@dimen/common_14_px"
        android:textColor="@color/mine_title_textcolor"
        android:id="@+id/common_mine_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="15dp"
        android:layout_toEndOf="@+id/iv_mine_left"/>
    <ImageView
        android:id="@+id/common_mine_txt_arrow"
        android:background="@drawable/mine_account_back"
        android:layout_width="12dp"
        android:layout_height="21dp"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="30dp"
        android:layout_alignParentEnd="true"/>
    <View
        android:id="@+id/buttom_view_line"
        android:background="@color/mine_separation_line_bg"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
