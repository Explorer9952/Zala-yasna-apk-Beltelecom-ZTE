<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/title_rlayout"
        android:background="@drawable/main_title_bg"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:paddingStart="5dp"
        android:paddingEnd="5dp">
        <TextView
            android:textSize="20sp"
            android:textColor="@color/menu_title"
            android:id="@+id/title_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/title_bottom_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:src="@color/divider_line_grey"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <EditText
            android:textSize="20sp"
            android:textColor="@color/text_grey_new1"
            android:id="@+id/etxt_config"
            android:background="@drawable/input_bg_grey"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="50dp"
            android:layout_marginStart="50dp"
            android:layout_marginEnd="50dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_config_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/ll_config"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"/>
            </ScrollView>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ll_debug"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">
                <TextView
                    android:textSize="16dp"
                    android:textColor="@color/text_grey_new1"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/txt_debug"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"/>
                <ToggleButton
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tg_debug"
                    android:background="@drawable/setting_switch_selector"
                    android:layout_width="70dp"
                    android:layout_height="45dp"
                    android:textOn=""
                    android:textOff=""/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ll_btn_buttom"
                android:background="@color/tv_watch_bg_grey"
                android:layout_width="match_parent"
                android:layout_height="58dp">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/text_grey_new1"
                    android:gravity="center"
                    android:id="@+id/txt_save"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.5"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/text_grey_new1"
                    android:gravity="center"
                    android:id="@+id/txt_cancel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.5"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
