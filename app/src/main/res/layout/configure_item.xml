<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_config_item"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">
        <TextView
            android:textSize="20sp"
            android:textColor="@color/text_grey_new1"
            android:layout_gravity="center_vertical"
            android:id="@+id/txt_config_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="20sp"
            android:textColor="@color/text_grey_new1"
            android:layout_gravity="center_vertical"
            android:id="@+id/txt_colon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <RelativeLayout
            android:layout_gravity="center_vertical"
            android:id="@+id/title_rlayout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="20sp"
                android:textColor="@color/text_grey_new1"
                android:id="@+id/txt_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"/>
            <EditText
                android:textSize="20sp"
                android:textColor="@color/text_grey_new1"
                android:id="@+id/etxt_config"
                android:background="@drawable/input_bg_grey"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_centerVertical="true"
                android:imeOptions="actionDone"/>
        </RelativeLayout>
    </LinearLayout>
    <ImageView
        android:layout_gravity="bottom"
        android:id="@+id/title_bottom_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:src="@color/divider_line_grey"/>
</FrameLayout>
