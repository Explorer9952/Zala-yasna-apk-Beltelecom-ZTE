<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:id="@+id/rl_subscription_time"
    android:background="@color/mine_order_editer_bg"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    skin:enable="true">
    <TextView
        android:textSize="@dimen/common_12_px"
        android:textColor="@color/mine_order_subscriptionname_textcolor"
        android:id="@+id/tv_subscription_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="15dp"
        android:layout_alignParentStart="true"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/img_arrow_down"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp"
        android:src="@drawable/btn_arrowup"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="10dp"
        android:layout_alignParentEnd="true"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/title_bottom_line1"
        android:background="@color/mine_order_itemseparator_color"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"
        android:contentDescription="@string/content_description"
        skin:enable="true"/>
</RelativeLayout>
