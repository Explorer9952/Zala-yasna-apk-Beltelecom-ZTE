<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:id="@+id/rl_introduction"
    android:background="@color/movie_detail_introduction_bg"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    skin:enable="true">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/ll_summary_title"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/common_14_px"
                android:textStyle="bold"
                android:textColor="@color/movie_detail_title_textcolor"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:id="@+id/txt_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:maxEms="12"
                android:lineSpacingMultiplier="1.2"
                skin:enable="true"/>
        </LinearLayout>
        <RelativeLayout
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/common_12_px"
                android:textColor="@color/movie_detail_rating_color"
                android:gravity="center_vertical"
                android:id="@+id/txt_price"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:singleLine="true"
                android:layout_centerVertical="true"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ll_introduction_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true">
                <TextView
                    android:textSize="@dimen/common_12_px"
                    android:textColor="@color/movie_detail_more_textcolor"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/introduction_more"
                    android:paddingRight="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="5dp"
                    skin:enable="true"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/more_icon"
                    android:background="@drawable/home_more_arrow_normal"
                    android:layout_width="10dp"
                    android:layout_height="15dp"
                    android:layout_centerVertical="true"/>
            </LinearLayout>
        </RelativeLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/video_detail_bottom_btn_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/iv_rating_pic"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="4dp"/>
            <TextView
                android:textSize="@dimen/common_12_px"
                android:textColor="@color/movie_detail_rating_color"
                android:gravity="center_vertical"
                android:id="@+id/txt_summary_sum"
                android:paddingLeft="10dp"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="1dp"
                android:singleLine="true"
                android:drawableLeft="@drawable/detail_rate"
                android:paddingStart="10dp"/>
            <TextView
                android:textSize="@dimen/common_12_px"
                android:textColor="@color/movie_detail_rating_color"
                android:gravity="center_vertical"
                android:id="@+id/txt_imdb"
                android:paddingLeft="10dp"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="1dp"
                android:singleLine="true"
                android:paddingStart="10dp"/>
            <TextView
                android:textSize="@dimen/common_12_px"
                android:textColor="@color/movie_detail_rating_color"
                android:gravity="center_vertical"
                android:id="@+id/txt_kino_poisk"
                android:paddingLeft="10dp"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="1dp"
                android:singleLine="true"
                android:paddingStart="10dp"/>
            <RelativeLayout
                android:layout_gravity="center_vertical"
                android:id="@+id/rl_duration_wrapper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen_detail_info_head_line_padding_left"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="1dp"
                android:layout_marginStart="@dimen/dimen_detail_info_head_line_padding_left">
                <ImageView
                    android:id="@+id/tv_duration_flag"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/detail_duration"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:textSize="@dimen/common_12_px"
                    android:textColor="@color/movie_detail_rating_color"
                    android:gravity="center_vertical"
                    android:id="@+id/txt_movie_duration"
                    android:paddingLeft="1dp"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:singleLine="true"
                    android:layout_toRightOf="@+id/tv_duration_flag"
                    android:paddingStart="1dp"/>
            </RelativeLayout>
            <TextView
                android:textSize="@dimen/common_12_px"
                android:textColor="@color/movie_detail_rating_color"
                android:gravity="center_vertical"
                android:id="@+id/txt_movie_release_year"
                android:background="@drawable/detail_release_year_stroke"
                android:paddingLeft="2dp"
                android:paddingRight="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="1dp"
                android:singleLine="true"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:layout_marginStart="10dp"/>
            <RelativeLayout
                android:layout_gravity="center_vertical"
                android:id="@+id/rl_series_season_wrapper"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen_detail_info_head_line_padding_left"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="1dp"
                android:layout_marginStart="@dimen/dimen_detail_info_head_line_padding_left">
                <ImageView
                    android:id="@+id/tv_series_season_flag"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/icon_detail_series_season"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:textSize="@dimen/common_12_px"
                    android:textColor="@color/movie_detail_rating_color"
                    android:gravity="center_vertical"
                    android:id="@+id/txt_series_season_num"
                    android:paddingLeft="1dp"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:singleLine="true"
                    android:layout_toRightOf="@+id/tv_series_season_flag"
                    android:layout_centerVertical="true"
                    android:paddingStart="1dp"/>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
    <Button
        android:textSize="16sp"
        android:textColor="@color/movie_detail_order_textcolor"
        android:id="@+id/btn_order"
        android:background="@drawable/detail_online_order"
        android:visibility="gone"
        android:layout_width="70dp"
        android:layout_height="30dp"
        android:layout_marginRight="10dp"
        android:layout_toLeftOf="@+id/ll_introduction_more"
        android:layout_centerVertical="true"
        android:layout_marginEnd="10dp"
        android:layout_toStartOf="@+id/ll_introduction_more"
        skin:enable="true"/>
</RelativeLayout>
