<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/tv_functionmenu_bg"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="50dp">
    <RelativeLayout
        android:id="@+id/rl_close_img_for_phone"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true">
        <ImageView
            android:id="@+id/img_close"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/img_close_style"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/movie_detail_title_textcolor"
        android:ellipsize="end"
        android:id="@+id/tv_video_title_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:maxLines="1"
        android:maxEms="12"
        android:layout_toLeftOf="@+id/rl_close_img_for_phone"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:layout_alignParentStart="true"/>
</RelativeLayout>
