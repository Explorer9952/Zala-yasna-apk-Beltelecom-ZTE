<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/movie_detailinfo_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    skin:enable="true">
    <View
        android:id="@+id/view_top_separator"
        android:background="@color/movie_separateline_color"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        skin:enable="true"/>
    <ScrollView
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <RelativeLayout
                android:layout_gravity="center"
                android:id="@+id/rl_poster_top"
                android:layout_width="@dimen/dimen_vod_poster_thumb_width"
                android:layout_height="@dimen/dimen_vod_poster_thumb_height"
                android:layout_marginTop="20dp">
                <ImageView
                    android:id="@+id/iv_poster_top"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:src="@drawable/default_poster_thumb"
                    android:scaleType="fitXY"/>
                <ImageView
                    android:id="@+id/ivi_logo_top"
                    android:visibility="gone"
                    android:layout_width="27.2dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="5dp"
                    android:src="@drawable/ivi_logo"
                    android:layout_alignParentRight="true"
                    android:layout_marginEnd="5dp"/>
            </RelativeLayout> 　
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <RelativeLayout
                    android:id="@+id/rl_poster_pic"
                    android:layout_width="@dimen/dimen_vod_poster_thumb_width"
                    android:layout_height="@dimen/dimen_vod_poster_thumb_height">
                    <ImageView
                        android:id="@+id/iv_poster_pic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="10dp"
                        android:src="@drawable/default_poster_thumb"
                        android:scaleType="fitXY"/>
                    <ImageView
                        android:id="@+id/ivi_logo"
                        android:visibility="gone"
                        android:layout_width="27.2dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="5dp"
                        android:src="@drawable/ivi_logo"
                        android:layout_alignParentRight="true"
                        android:layout_marginEnd="5dp"/>
                </RelativeLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/ll_small_desc_container"
                    android:background="@color/movie_detailinfo_bg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginBottom="5dp"
                    skin:enable="true">
                    <RelativeLayout
                        android:id="@+id/rl_detail_head_wrapper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            skin:enable="true">
                            <TextView
                                android:textSize="@dimen/common_14_px"
                                android:textStyle="bold"
                                android:textColor="@color/movie_detailinfo_head_color"
                                android:ellipsize="end"
                                android:id="@+id/mtxt_title"
                                android:paddingLeft="10dp"
                                android:paddingRight="10dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:maxEms="12"
                                android:layout_centerVertical="true"
                                android:lineSpacingMultiplier="1.2"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                skin:enable="true"/>
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:textSize="@dimen/common_12_px"
                                    android:textColor="@color/movie_detail_rating_color"
                                    android:gravity="center_vertical"
                                    android:layout_gravity="center_vertical"
                                    android:id="@+id/txt_price"
                                    android:paddingLeft="10dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:singleLine="true"
                                    android:paddingStart="10dp"/>
                                <RelativeLayout
                                    android:id="@+id/rl_detail_next_container"
                                    android:layout_width="180dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginRight="6dp"
                                    android:layout_alignParentRight="true"
                                    android:layout_centerVertical="true">
                                    <ImageView
                                        android:id="@+id/img_detail_next"
                                        android:layout_width="10dp"
                                        android:layout_height="15dp"
                                        android:layout_marginRight="10dp"
                                        android:src="@drawable/home_more_arrow_normal"
                                        android:layout_alignParentRight="true"
                                        android:layout_centerVertical="true"
                                        android:layout_marginEnd="10dp"
                                        android:layout_alignParentEnd="true"/>
                                    <TextView
                                        android:textSize="@dimen/common_12_px"
                                        android:textColor="@color/movie_detailinfo_head_color"
                                        android:gravity="center_vertical"
                                        android:id="@+id/href_detail_next"
                                        android:paddingRight="5dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="match_parent"
                                        android:text="@string/detail_introduction"
                                        android:layout_toLeftOf="@+id/img_detail_next"
                                        android:layout_centerVertical="true"
                                        android:paddingEnd="5dp"/>
                                </RelativeLayout>
                            </RelativeLayout>
                            <LinearLayout
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:id="@+id/hd_video_detail_bottom_btn_rating"
                                android:paddingLeft="10dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="10dp">
                                <ImageView
                                    android:layout_gravity="center_vertical"
                                    android:id="@+id/iv_rating_pic"
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_marginTop="4dp"/>
                                <TextView
                                    android:textSize="@dimen/common_12_px"
                                    android:textColor="@color/movie_detail_rating_color"
                                    android:gravity="center_vertical"
                                    android:id="@+id/hd_txt_summary_sum"
                                    android:paddingLeft="@dimen/dimen_detail_info_head_line_padding_left"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:layout_marginTop="4dp"
                                    android:layout_marginBottom="1dp"
                                    android:singleLine="true"
                                    android:drawableLeft="@drawable/detail_rate"
                                    android:paddingStart="@dimen/dimen_detail_info_head_line_padding_left"/>
                                <TextView
                                    android:textSize="@dimen/common_12_px"
                                    android:textColor="@color/movie_detail_rating_color"
                                    android:gravity="center_vertical"
                                    android:id="@+id/txt_imdb"
                                    android:paddingLeft="@dimen/dimen_detail_info_head_line_padding_left"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:layout_marginTop="4dp"
                                    android:layout_marginBottom="1dp"
                                    android:singleLine="true"
                                    android:paddingStart="@dimen/dimen_detail_info_head_line_padding_left"/>
                                <TextView
                                    android:textSize="@dimen/common_12_px"
                                    android:textColor="@color/movie_detail_rating_color"
                                    android:gravity="center_vertical"
                                    android:id="@+id/txt_kino_poisk"
                                    android:paddingLeft="@dimen/dimen_detail_info_head_line_padding_left"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:layout_marginTop="4dp"
                                    android:layout_marginBottom="1dp"
                                    android:singleLine="true"
                                    android:paddingStart="@dimen/dimen_detail_info_head_line_padding_left"/>
                                <RelativeLayout
                                    android:layout_gravity="center_vertical"
                                    android:id="@+id/rl_duration_wrapper"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="@dimen/dimen_detail_info_head_line_padding_left"
                                    android:layout_marginTop="4dp"
                                    android:layout_marginBottom="1dp"
                                    android:layout_marginStart="@dimen/dimen_detail_info_head_line_padding_left">
                                    <ImageView
                                        android:id="@+id/tv_duration_flag"
                                        android:layout_width="14dp"
                                        android:layout_height="14dp"
                                        android:src="@drawable/detail_duration"
                                        android:layout_centerVertical="true"/>
                                    <TextView
                                        android:textSize="@dimen/common_12_px"
                                        android:textColor="@color/movie_detail_rating_color"
                                        android:gravity="center_vertical"
                                        android:id="@+id/txt_movie_duration"
                                        android:paddingLeft="1dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="32dp"
                                        android:singleLine="true"
                                        android:layout_toRightOf="@+id/tv_duration_flag"
                                        android:layout_centerVertical="true"
                                        android:paddingStart="1dp"/>
                                </RelativeLayout>
                                <TextView
                                    android:textSize="@dimen/common_12_px"
                                    android:textColor="@color/movie_detail_rating_color"
                                    android:gravity="center_vertical"
                                    android:id="@+id/txt_movie_release_year"
                                    android:background="@drawable/detail_release_year_stroke"
                                    android:paddingLeft="2dp"
                                    android:paddingRight="2dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="@dimen/dimen_detail_info_head_line_padding_left"
                                    android:layout_marginTop="4dp"
                                    android:layout_marginBottom="1dp"
                                    android:singleLine="true"
                                    android:paddingStart="2dp"
                                    android:paddingEnd="2dp"
                                    android:layout_marginStart="@dimen/dimen_detail_info_head_line_padding_left"/>
                                <RelativeLayout
                                    android:layout_gravity="center_vertical"
                                    android:id="@+id/rl_series_season_wrapper"
                                    android:visibility="gone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="@dimen/dimen_detail_info_head_line_padding_left"
                                    android:layout_marginTop="4dp"
                                    android:layout_marginBottom="1dp"
                                    android:layout_marginStart="@dimen/dimen_detail_info_head_line_padding_left">
                                    <ImageView
                                        android:id="@+id/tv_series_season_flag"
                                        android:layout_width="14dp"
                                        android:layout_height="14dp"
                                        android:src="@drawable/icon_detail_series_season"
                                        android:layout_centerVertical="true"/>
                                    <TextView
                                        android:textSize="@dimen/common_12_px"
                                        android:textColor="@color/movie_detail_rating_color"
                                        android:gravity="center_vertical"
                                        android:id="@+id/txt_series_season_num"
                                        android:paddingLeft="1dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="32dp"
                                        android:singleLine="true"
                                        android:layout_toRightOf="@+id/tv_series_season_flag"
                                        android:layout_centerVertical="true"
                                        android:paddingStart="1dp"/>
                                </RelativeLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </RelativeLayout>
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <RelativeLayout
                            android:id="@+id/rl_colse_img"
                            android:paddingRight="10dp"
                            android:visibility="gone"
                            android:layout_width="60dp"
                            android:layout_height="match_parent"
                            android:layout_alignParentRight="true"
                            android:paddingEnd="10dp"
                            android:layout_alignParentEnd="true">
                            <ImageView
                                android:id="@+id/img_close"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/img_close_style"
                                android:layout_alignParentRight="true"
                                android:layout_centerVertical="true"
                                android:layout_alignParentEnd="true"/>
                        </RelativeLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/ll_detail_program_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/rl_colse_img">
                            <LinearLayout style="@style/style_layout_vod_left_bottom_container_indicate">
                                <TextView
                                    android:id="@+id/text_star_title"
                                    style="@style/style_text_vod_left_bottom_info_indicate"/>
                            </LinearLayout>
                            <LinearLayout style="@style/style_layout_vod_left_bottom_container_indicate">
                                <TextView
                                    android:id="@+id/txt_director_title"
                                    style="@style/style_text_vod_left_bottom_info_indicate"/>
                            </LinearLayout>
                            <LinearLayout style="@style/style_layout_vod_left_bottom_container_indicate">
                                <TextView
                                    android:id="@+id/txt_gene_title"
                                    style="@style/style_text_vod_left_bottom_info_indicate"/>
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/ll_language_container"
                                style="@style/style_layout_vod_left_bottom_container_indicate">
                                <TextView
                                    android:id="@+id/text_language"
                                    style="@style/style_text_vod_left_bottom_info_indicate"/>
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/ll_country_container"
                                android:visibility="gone"
                                style="@style/style_layout_vod_left_bottom_container_indicate">
                                <TextView
                                    android:id="@+id/txt_country_title"
                                    style="@style/style_text_vod_left_bottom_info_indicate"/>
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/ll_subtitle_container"
                                android:visibility="gone"
                                style="@style/style_layout_vod_left_bottom_container_indicate">
                                <TextView
                                    android:id="@+id/text_subtitle"
                                    style="@style/style_text_vod_left_bottom_info_indicate"/>
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/ll_audio_container"
                                android:visibility="gone"
                                style="@style/style_layout_vod_left_bottom_container_indicate">
                                <TextView
                                    android:id="@+id/text_audio"
                                    style="@style/style_text_vod_left_bottom_info_indicate"/>
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/ll_pubcompany_container"
                                android:visibility="gone"
                                style="@style/style_layout_vod_left_bottom_container_indicate">
                                <TextView
                                    android:id="@+id/text_pubcompany"
                                    style="@style/style_text_vod_left_bottom_info_indicate"/>
                            </LinearLayout>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/detail_program_introduction"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">
                <TextView
                    android:textSize="@dimen/video_detail_info_textsize_hd"
                    android:textColor="@color/movie_detailinfo_title_color"
                    android:layout_gravity="top"
                    android:id="@+id/txt_desc_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginEnd="5dp"
                    skin:enable="true"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
