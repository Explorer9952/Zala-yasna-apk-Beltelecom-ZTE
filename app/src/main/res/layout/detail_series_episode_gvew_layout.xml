<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <RelativeLayout
        android:layout_gravity="center"
        android:id="@+id/rl_series_episode_gvew_txtvew_item"
        android:background="@drawable/episode_item_bg"
        android:layout_width="55dp"
        android:layout_height="55dp">
        <TextView
            android:textSize="19sp"
            android:textStyle="normal"
            android:textColor="@color/movie_serieslist_number_textcolor"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/detail_series_episode_gvew_txtvew"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:singleLine="true"
            android:layout_centerInParent="true"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/download_state"
            android:visibility="visible"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</LinearLayout>
