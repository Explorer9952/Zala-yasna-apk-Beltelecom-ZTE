<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:background="@color/mine_download_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:splitMotionEvents="false"
    skin:enable="true">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_item_all"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_item"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="match_parent"
            android:layout_height="129dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">
            <ImageView
                android:id="@+id/img_check"
                android:background="@drawable/download_check_bg"
                android:visibility="gone"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginRight="12dp"
                android:layout_marginEnd="12dp"
                skin:enable="true"/>
            <FrameLayout
                android:layout_gravity="center_vertical"
                android:id="@+id/fl_poster"
                android:layout_width="67dp"
                android:layout_height="97dp"
                android:layout_marginRight="12dp"
                android:layout_marginEnd="12dp">
                <ImageView
                    android:id="@+id/img_poster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/default_poster_thumb"
                    android:scaleType="fitXY"
                    skin:enable="true"/>
                <ImageView
                    android:id="@+id/img_poster_paused"
                    android:background="@color/mine_download_downloadingposter_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/post_mask_paused"
                    android:scaleType="centerInside"
                    skin:enable="true"/>
            </FrameLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="12dp"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="18dp"
                        android:textColor="@color/mine_poster_title_textcolor"
                        android:id="@+id/list_item_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        skin:enable="true"/>
                    <TextView
                        android:textSize="18dp"
                        android:textColor="@color/mine_poster_title_textcolor"
                        android:id="@+id/tv_series_index"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginStart="10dp"
                        skin:enable="true"/>
                </LinearLayout>
                <RelativeLayout
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <ImageView
                        android:id="@+id/img_cloud"
                        android:visibility="invisible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="5dp"
                        android:src="@drawable/hc_cloud"
                        android:layout_toLeftOf="@+id/list_item_store_path"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="5dp"
                        android:layout_toStartOf="@+id/list_item_store_path"
                        skin:enable="true"/>
                    <TextView
                        android:textSize="16dp"
                        android:textColor="@color/mine_download_loacaltext_textcolor"
                        android:id="@+id/list_item_store_path"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:layout_alignParentRight="true"
                        android:layout_alignParentEnd="true"
                        skin:enable="true"/>
                </RelativeLayout>
                <RelativeLayout
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="16dp"
                        android:textColor="@color/mine_download_videosize_textcolor"
                        android:id="@+id/list_item_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:layout_alignParentRight="true"
                        android:layout_alignParentEnd="true"
                        skin:enable="true"/>
                    <TextView
                        android:textSize="16dp"
                        android:textColor="@color/downloading_list_item_status"
                        android:id="@+id/list_item_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:layout_alignParentLeft="true"
                        android:layout_alignParentStart="true"
                        skin:enable="true"/>
                    <TextView
                        android:textSize="16dp"
                        android:textColor="@color/mine_download_rate_textcolor"
                        android:id="@+id/txt_download_speed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_toRightOf="@+id/list_item_status"
                        android:layout_marginStart="10dp"
                        android:layout_toEndOf="@+id/list_item_status"
                        skin:enable="true"/>
                </RelativeLayout>
                <RelativeLayout
                    android:layout_gravity="bottom"
                    android:id="@+id/rl_processbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ProgressBar
                        android:id="@+id/downloading_progressbar_light"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="5dp"
                        android:progress="10"
                        android:progressDrawable="@drawable/shape_progressbar_mini_light"
                        style="?android:attr/progressBarStyleHorizontal"/>
                    <ProgressBar
                        android:id="@+id/downloading_progressbar_dark"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="5dp"
                        android:progress="10"
                        android:progressDrawable="@drawable/shape_progressbar_mini_dark"
                        style="?android:attr/progressBarStyleHorizontal"/>
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
        <View
            android:id="@+id/bottom_line"
            android:background="@color/mine_download_separateline_color"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0.5px"
            skin:enable="true"/>
    </LinearLayout>
</FrameLayout>
