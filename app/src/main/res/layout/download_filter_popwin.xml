<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/popwin_filter_llayout"
        android:background="@drawable/pop_arrow_bg"
        android:layout_width="200dp"
        android:layout_height="100dp">
        <TextView
            android:textColor="@color/text_grey_new3"
            android:gravity="center"
            android:id="@+id/popwin_filter_local_txtview"
            android:layout_width="match_parent"
            android:layout_height="48dp"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:src="@color/divider_line_grey"/>
        <TextView
            android:textColor="@color/text_grey_new3"
            android:gravity="center"
            android:id="@+id/popwin_filter_stb_txtview"
            android:layout_width="match_parent"
            android:layout_height="48dp"/>
    </LinearLayout>
</LinearLayout>
