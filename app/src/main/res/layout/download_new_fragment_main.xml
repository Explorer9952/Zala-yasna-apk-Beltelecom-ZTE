<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/mine_download_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:baselineAligned="false"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/mine_download_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:id="@+id/title_rlayout"
            android:background="@color/mine_download_title_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mine_fragment_myaccount_ll_height"
            skin:enable="true">
            <Button
                android:id="@+id/btn_back"
                android:background="@drawable/title_back_bg"
                android:visibility="gone"
                android:layout_width="43dp"
                android:layout_height="52dp"
                android:layout_centerVertical="true"
                skin:enable="true"/>
            <TextView
                android:textSize="@dimen/title_textsize"
                android:textColor="@color/mine_download_title_textcolor"
                android:id="@+id/title_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                skin:enable="true"/>
            <TextView
                android:textSize="20sp"
                android:textColor="@color/mine_download_menu_textcolor"
                android:id="@+id/edit_txt"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginEnd="15dp"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true">
                <ImageView
                    android:id="@+id/edit_ivew"
                    android:background="@drawable/title_edit_style"
                    android:visibility="gone"
                    android:layout_width="43dp"
                    android:layout_height="52dp"
                    android:layout_marginRight="15dp"
                    android:layout_marginEnd="15dp"
                    skin:enable="true"/>
                <ImageView
                    android:id="@+id/filter_ivew"
                    android:background="@drawable/title_filter_style"
                    android:visibility="gone"
                    android:layout_width="43dp"
                    android:layout_height="52dp"
                    android:layout_marginRight="15dp"
                    android:layout_marginEnd="15dp"
                    skin:enable="true"/>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/edit_rlayout"
            android:background="@color/mine_download_titlebar_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="66dp"
            skin:enable="true">
            <TextView
                android:textSize="20sp"
                android:textColor="@color/mine_download_titlebar_textcolor"
                android:id="@+id/txt_selected_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"
                skin:enable="true"/>
            <TextView
                android:textSize="@dimen/title_textsize"
                android:textColor="@color/mine_download_titlebar_textcolor"
                android:id="@+id/txt_selected_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                skin:enable="true"/>
            <TextView
                android:textSize="20sp"
                android:textColor="@color/mine_download_titlebar_textcolor"
                android:id="@+id/txt_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginEnd="15dp"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
        </RelativeLayout>
    </RelativeLayout>
    <ImageView
        android:id="@+id/title_bottom_line"
        android:background="@color/mine_download_separateline_color"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/rl_tag"
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <LinearLayout
            android:orientation="horizontal"
            android:background="@color/mine_download_tag_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            skin:enable="true">
            <RelativeLayout
                android:id="@+id/rl_downloaded"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <TextView
                    android:textSize="16sp"
                    android:gravity="center"
                    android:id="@+id/tag_title01"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_alignParentTop="true"/>
                <ImageView
                    android:id="@+id/bottom_line01"
                    android:background="@color/mine_download_separatelinetag_color"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_alignLeft="@+id/tag_title01"
                    android:layout_alignRight="@+id/tag_title01"
                    android:layout_alignParentBottom="true"
                    android:layout_alignStart="@+id/tag_title01"
                    android:layout_alignEnd="@+id/tag_title01"
                    skin:enable="true"/>
            </RelativeLayout>
            <View
                android:id="@+id/line_1"
                android:background="@color/mine_download_separatelinetag_color"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                skin:enable="true"/>
            <RelativeLayout
                android:id="@+id/rl_downloading"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <TextView
                    android:textSize="16sp"
                    android:gravity="center"
                    android:id="@+id/tag_title02"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <ImageView
                    android:id="@+id/bottom_line02"
                    android:background="@color/mine_download_separatelinetag_color"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_alignLeft="@+id/tag_title02"
                    android:layout_alignRight="@+id/tag_title02"
                    android:layout_alignParentBottom="true"
                    android:layout_alignStart="@+id/tag_title02"
                    android:layout_alignEnd="@+id/tag_title02"
                    skin:enable="true"/>
            </RelativeLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/cursor"
            android:background="@color/download_tag_title_selected"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:scaleType="fitXY"
            android:layout_alignParentBottom="true"
            android:transformPivotX="0dp"
            skin:enable="true"/>
    </RelativeLayout>
    <FrameLayout
        android:background="@color/mine_download_tag_bg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        skin:enable="true">
        <com.zte.iptvclient.android.common.customview.viewpager.SlideViewPager
            android:id="@+id/viewpager"
            android:background="@color/mine_download_tag_bg"
            android:paddingBottom="36dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            skin:enable="true"/>
        <RelativeLayout
            android:layout_gravity="bottom"
            android:id="@+id/rl_download_storage_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:id="@+id/download_storage_bar_light"
                android:background="@color/mine_download_localstorage_bg"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                skin:enable="true">
                <ProgressBar
                    android:layout_gravity="bottom"
                    android:id="@+id/download_local_storage_progressbar_light"
                    android:background="@color/mine_download_localstorage_bg"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:progress="10"
                    android:progressDrawable="@drawable/download_storage_progressbar"
                    style="?android:attr/progressBarStyleHorizontal"
                    skin:enable="true"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/mine_download_localstorage_textcolor"
                    android:layout_gravity="center"
                    android:id="@+id/download_main_space_light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    skin:enable="true"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/download_storage_bar_dark"
                android:background="@color/mine_download_localstorage_bg"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                skin:enable="true">
                <ProgressBar
                    android:layout_gravity="bottom"
                    android:id="@+id/download_local_storage_progressbar_dark"
                    android:background="@color/mine_download_localstorage_bg"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:progress="10"
                    android:progressDrawable="@drawable/download_storage_progressbar_dark"
                    style="?android:attr/progressBarStyleHorizontal"
                    skin:enable="true"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/mine_download_localstorage_textcolor"
                    android:layout_gravity="center"
                    android:id="@+id/download_main_space_dark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    skin:enable="true"/>
            </FrameLayout>
        </RelativeLayout>
        <FrameLayout
            android:layout_gravity="bottom"
            android:id="@+id/fl_delete"
            android:background="@color/mine_download_delete_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            skin:enable="true">
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:id="@+id/ll_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/img_delete"
                    android:background="@drawable/myfav_action_delete"
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    skin:enable="true"/>
                <TextView
                    android:textSize="20sp"
                    android:textColor="@color/mine_download_delete_textcolor"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/txt_delete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_marginStart="8dp"
                    skin:enable="true"/>
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>
</LinearLayout>
