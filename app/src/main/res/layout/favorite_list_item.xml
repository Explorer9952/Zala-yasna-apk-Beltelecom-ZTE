<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="horizontal"
    android:id="@+id/ll_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    skin:enable="true">
    <TextView
        android:textSize="18sp"
        android:textColor="@color/mine_favorite_listitem_textcolor"
        android:ellipsize="end"
        android:id="@+id/txt_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="15dp"
        android:singleLine="true"
        android:layout_weight="1"
        android:layout_marginStart="20dp"
        skin:enable="true"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/img_select"
        android:background="@drawable/favorite_video_select"
        android:visibility="invisible"
        android:layout_width="25dp"
        android:layout_height="19dp"
        android:layout_marginRight="20dp"
        android:layout_marginEnd="20dp"
        skin:enable="true"/>
</LinearLayout>
