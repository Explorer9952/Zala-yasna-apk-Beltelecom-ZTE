<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@drawable/bg_child"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/transparent"
        style="@style/top_bar"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/favorite_rlayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:id="@+id/title_rlayout"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mine_fragment_myaccount_ll_height"
            skin:enable="true">
            <TextView
                android:textSize="@dimen/title_textsize"
                android:textColor="@color/mine_favorite_title_textcolor"
                android:id="@+id/title_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                skin:enable="true"/>
        </RelativeLayout>
    </RelativeLayout>
    <ImageView
        android:id="@+id/title_bottom_line"
        android:background="@color/mine_favorite_separateline_bg"
        android:layout_width="match_parent"
        android:layout_height="1px"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/rl_tag"
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            skin:enable="true">
            <RelativeLayout
                android:id="@+id/rl_ppv"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/child_watch_history_tab_text_color"
                    android:gravity="center"
                    android:id="@+id/tag_title01"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/today"
                    android:layout_alignParentTop="true"/>
                <ImageView
                    android:id="@+id/bottom_line01"
                    android:background="@color/recording_separateline_color"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_alignLeft="@+id/tag_title01"
                    android:layout_alignRight="@+id/tag_title01"
                    android:layout_alignParentBottom="true"
                    android:layout_alignStart="@+id/tag_title01"
                    android:layout_alignEnd="@+id/tag_title01"
                    skin:enable="true"/>
            </RelativeLayout>
            <View
                android:id="@+id/line_1"
                android:background="@color/recording_separateline_color"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                skin:enable="true"/>
            <RelativeLayout
                android:id="@+id/rl_tvod"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/child_watch_history_tab_text_color"
                    android:gravity="center"
                    android:id="@+id/tag_title02"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/yesterday"/>
                <ImageView
                    android:id="@+id/bottom_line02"
                    android:background="@color/recording_separateline_color"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_alignLeft="@+id/tag_title02"
                    android:layout_alignRight="@+id/tag_title02"
                    android:layout_alignParentBottom="true"
                    android:layout_alignStart="@+id/tag_title02"
                    android:layout_alignEnd="@+id/tag_title02"
                    skin:enable="true"/>
            </RelativeLayout>
            <View
                android:id="@+id/line_2"
                android:background="@color/recording_separateline_color"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                skin:enable="true"/>
            <RelativeLayout
                android:id="@+id/rl_concrete_time"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/child_watch_history_tab_text_color"
                    android:gravity="center"
                    android:id="@+id/tag_title03"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <ImageView
                    android:id="@+id/bottom_line03"
                    android:background="@color/recording_separateline_color"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_alignLeft="@+id/tag_title03"
                    android:layout_alignRight="@+id/tag_title03"
                    android:layout_alignParentBottom="true"
                    android:layout_alignStart="@+id/tag_title03"
                    android:layout_alignEnd="@+id/tag_title03"
                    skin:enable="true"/>
            </RelativeLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/cursor"
            android:background="@color/white"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:scaleType="fitXY"
            android:layout_alignParentBottom="true"
            android:transformPivotX="0dp"
            skin:enable="true"/>
    </RelativeLayout>
    <androidx.viewpager.widget.ViewPager
        android:id="@+id/vp_my_ppv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
