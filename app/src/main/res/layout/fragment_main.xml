<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:skin="http://schemas.android.com/android/skin"
    android:id="@+id/rl_home"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/fl_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignWithParentIfMissing="true"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_tabs"
        android:background="@color/home_botttom_tab_bg"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_tabs_height"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        skin:enable="true"/>
    <View
        android:background="@color/home_bottom_tab_top_line"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mainfragment_bottom_tabs_topline_height"
        android:layout_alignTop="@+id/ll_tabs"/>
    <ImageView
        android:id="@+id/img_interact"
        android:layout_width="75dp"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
