<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/ll_setting_play_file"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/top"
        android:background="@color/mine_record_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/layout_linear"
        android:background="@color/home_blur_bg_color"
        android:layout_width="match_parent"
        android:layout_height="63dp">
        <ImageView
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/iv_back_movie_file_setting"
            android:layout_width="30dp"
            android:layout_height="40dp"
            android:layout_marginLeft="25dp"
            android:src="@drawable/photo_back"
            android:layout_marginStart="25dp"/>
        <TextView
            android:textSize="21sp"
            android:textColor="@color/tv_full_screen_line"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/txt_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <TextView
            android:textSize="21sp"
            android:textColor="@color/tv_finish_color"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/tv_finish_movie_file_setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="16dp"
            android:layout_marginEnd="16dp"/>
    </LinearLayout>
    <com.scwang.smartrefresh.layout.SmartRefreshLayout
        android:id="@+id/SmartRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <GridView
            android:id="@+id/grid_view_movie_setting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            android:numColumns="2"/>
    </com.scwang.smartrefresh.layout.SmartRefreshLayout>
</LinearLayout>
