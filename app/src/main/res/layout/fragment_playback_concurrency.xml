<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/mine_favorite_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/mine_favorite_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/title_rlayout"
        android:background="@color/mine_favorite_title_bg"
        android:layout_width="match_parent"
        android:layout_height="63dp"
        skin:enable="true">
        <Button
            android:id="@+id/btn_back"
            android:background="@drawable/title_back_bg"
            android:layout_width="43dp"
            android:layout_height="52dp"
            android:layout_centerVertical="true"
            skin:enable="true"/>
        <TextView
            android:textSize="23sp"
            android:textColor="@color/mine_favorite_title_textcolor"
            android:id="@+id/title_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            skin:enable="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="19sp"
        android:textColor="@color/concurrency_play_orange"
        android:gravity="end|center_vertical"
        android:id="@+id/txt_total"
        android:background="@color/mine_order_editer_bg"
        android:paddingRight="20dp"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:paddingEnd="20dp"
        skin:enable="true"/>
    <ListView
        android:id="@+id/lst_porduct"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp"/>
</LinearLayout>
