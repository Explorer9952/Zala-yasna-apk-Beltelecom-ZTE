<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/mine_ppv_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:baselineAligned="false"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/mine_ppv_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:id="@+id/title_rlayout"
            android:background="@color/mine_ppv_title_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mine_fragment_myaccount_ll_height"
            skin:enable="true">
            <Button
                android:id="@+id/btn_back"
                android:background="@drawable/title_back_bg"
                android:layout_width="43dp"
                android:layout_height="52dp"
                android:layout_centerVertical="true"
                skin:enable="true"/>
            <TextView
                android:textSize="@dimen/title_textsize"
                android:textColor="@color/mine_ppv_title_textcolor"
                android:id="@+id/title_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                skin:enable="true"/>
        </RelativeLayout>
    </RelativeLayout>
    <ImageView
        android:id="@+id/title_bottom_line"
        android:background="@color/mine_ppv_separateline_color"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/rl_tag"
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <LinearLayout
            android:orientation="horizontal"
            android:background="@color/mine_ppv_tag_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            skin:enable="true">
            <RelativeLayout
                android:id="@+id/rl_vod"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <TextView
                    android:textSize="16sp"
                    android:gravity="center"
                    android:id="@+id/tag_title01"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_alignParentTop="true"/>
                <ImageView
                    android:id="@+id/bottom_line01"
                    android:background="@color/mine_ppv_separatelinetag_color"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_alignLeft="@+id/tag_title01"
                    android:layout_alignRight="@+id/tag_title01"
                    android:layout_alignParentBottom="true"
                    android:layout_alignStart="@+id/tag_title01"
                    android:layout_alignEnd="@+id/tag_title01"
                    skin:enable="true"/>
            </RelativeLayout>
            <View
                android:id="@+id/line_1"
                android:background="@color/mine_ppv_separatelinetag_color"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                skin:enable="true"/>
            <RelativeLayout
                android:id="@+id/rl_tv"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <TextView
                    android:textSize="16sp"
                    android:gravity="center"
                    android:id="@+id/tag_title02"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <ImageView
                    android:id="@+id/bottom_line02"
                    android:background="@color/mine_ppv_separatelinetag_color"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_alignLeft="@+id/tag_title02"
                    android:layout_alignRight="@+id/tag_title02"
                    android:layout_alignParentBottom="true"
                    android:layout_alignStart="@+id/tag_title02"
                    android:layout_alignEnd="@+id/tag_title02"
                    skin:enable="true"/>
            </RelativeLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/cursor"
            android:background="@color/ppv_tag_title_selected"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:scaleType="fitXY"
            android:layout_alignParentBottom="true"
            android:transformPivotX="0dp"
            skin:enable="true"/>
    </RelativeLayout>
    <FrameLayout
        android:background="@color/mine_ppv_tag_bg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        skin:enable="true">
        <androidx.viewpager.widget.ViewPager
            android:id="@+id/viewpager"
            android:background="@color/mine_ppv_tag_bg"
            android:paddingBottom="36dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            skin:enable="true"/>
        <com.zte.iptvclient.android.mobile.ppv.recycle.RtlViewPager
            android:id="@+id/rtl_viewpager"
            android:background="@color/mine_ppv_tag_bg"
            android:paddingBottom="36dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            skin:enable="true"/>
    </FrameLayout>
</LinearLayout>
