<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/recording_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/fragment_recording_shedules_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <RelativeLayout
        android:id="@+id/fragment_recording_shedules_header_rl"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@+id/fragment_recording_shedules_top">
        <Button
            android:gravity="center_vertical"
            android:id="@+id/fragment_recording_schedules_btn_back"
            android:background="@drawable/title_back_bg"
            android:visibility="visible"
            android:layout_width="30dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/recording_text"
            android:id="@+id/fragment_recording_schedules_title_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/recording_text"
            android:gravity="center"
            android:id="@+id/fragment_recording_schedules_edit_txt"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginRight="10dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/recording_text"
            android:gravity="center"
            android:id="@+id/fragment_recording_schedules_selectall_txt"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginRight="10dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"/>
        <ImageView
            android:id="@+id/fragment_recording_schedules_header_bottom_line"
            android:background="@color/video_separateline_color"
            android:layout_width="match_parent"
            android:layout_height="0.5px"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/fragment_recording_schedules_sort_rl"
        android:background="@color/recording_sortline_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/fragment_recording_shedules_header_rl">
        <Spinner
            android:theme="@style/SpinnerStyle"
            android:textColor="@color/recording_text"
            android:id="@+id/fragment_recording_schedules_sort_spinner"
            android:background="@null"
            android:layout_width="160dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="13dp"
        android:textColor="@color/recording_uservolumn_text"
        android:gravity="center"
        android:id="@+id/fragment_recording_schedules_bottom_uservolume_txt"
        android:background="@color/recording_uservolumn_bg"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_alignParentBottom="true"/>
    <TextView
        android:textSize="16dp"
        android:textColor="@color/recording_delete_text"
        android:gravity="center"
        android:id="@+id/fragment_recording_schedules_bottom_delete_txt"
        android:background="@color/recording_delete_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_alignParentBottom="true"/>
    <com.zte.iptvclient.android.mobile.clouddvr.mvp.view.adapter.LeftSlideDeleteRecyclerview
        android:id="@+id/fragment_recording_schedules_recyclerview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/fragment_recording_schedules_bottom_uservolume_txt"
        android:layout_below="@+id/fragment_recording_schedules_sort_rl"/>
</RelativeLayout>
