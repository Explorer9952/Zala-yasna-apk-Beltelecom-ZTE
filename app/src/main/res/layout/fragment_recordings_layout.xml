<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/video_more_title_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/mine_favorite_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/rl_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mine_fragment_myaccount_ll_height">
        <Button
            android:gravity="center_vertical"
            android:id="@+id/fragment_recordings_btn_back"
            android:background="@drawable/title_back_bg"
            android:visibility="visible"
            android:layout_width="43dp"
            android:layout_height="@dimen/back_btn_height"
            android:layout_centerVertical="true"
            skin:enable="true"/>
        <TextView
            android:textSize="@dimen/title_textsize"
            android:textColor="@color/video_more_title_textcolor"
            android:id="@+id/fragment_recordings_title_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/fragment_recordings_header_bottom_line"
            android:background="@color/video_separateline_color"
            android:layout_width="match_parent"
            android:layout_height="0.5px"
            android:layout_alignParentBottom="true"
            skin:enable="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/fragment_recordings_shedules_rl"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <TextView
            android:textSize="18dp"
            android:textColor="@color/mine_title_textcolor"
            android:id="@+id/fragment_recordings_shedules_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/fragment_recordings_shedules_arrow_img"
            android:background="@drawable/mine_account_back"
            android:layout_width="10dp"
            android:layout_height="18dp"
            android:layout_marginRight="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="30dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/fragment_recordings_manager_rl"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <TextView
            android:textSize="18dp"
            android:textColor="@color/mine_title_textcolor"
            android:id="@+id/fragment_recordings_manager_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/fragment_recordings_manager_arrow_img"
            android:background="@drawable/mine_account_back"
            android:layout_width="10dp"
            android:layout_height="18dp"
            android:layout_marginRight="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="30dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/fragment_recordings_history_rl"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <TextView
            android:textSize="18dp"
            android:textColor="@color/mine_title_textcolor"
            android:id="@+id/fragment_recordings_history_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/fragment_recordings_history_arrow_img"
            android:background="@drawable/mine_account_back"
            android:layout_width="10dp"
            android:layout_height="18dp"
            android:layout_marginRight="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="30dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
    </RelativeLayout>
</LinearLayout>
