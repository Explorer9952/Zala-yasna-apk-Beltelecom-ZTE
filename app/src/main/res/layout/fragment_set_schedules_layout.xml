<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/recording_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/fragment_setschedules_top"
        android:background="@color/recording_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <RelativeLayout
        android:id="@+id/title_header_rl"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mine_fragment_myaccount_ll_height">
        <Button
            android:gravity="center_vertical"
            android:id="@+id/fragment_setschedules_btn_back"
            android:background="@drawable/title_back_bg"
            android:visibility="visible"
            android:layout_width="30dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/recording_text"
            android:id="@+id/fragment_setschedules_title_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/recording_text"
            android:id="@+id/fragment_setschedules_confirm_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="30dp"
            android:layout_alignParentEnd="true"/>
        <ImageView
            android:id="@+id/fragment_setschedules_header_bottom_line"
            android:background="@color/recording_line_bg"
            android:layout_width="match_parent"
            android:layout_height="0.5px"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="14dp"
        android:textColor="@color/recording_modify_default_content_text"
        android:gravity="center_vertical"
        android:id="@+id/fragment_setschedules_schedule_title_txt"
        android:background="@color/recording_sort_bg"
        android:paddingLeft="20dp"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:paddingStart="20dp"/>
    <RelativeLayout
        android:id="@+id/fragment_setschedules_start_rl"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <TextView
            android:textSize="14dp"
            android:textColor="@color/recording_item_text"
            android:id="@+id/fragment_setschedules_start_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"/>
        <ImageView
            android:id="@+id/fragment_setschedules_start_arrow_img"
            android:background="@drawable/mine_account_back"
            android:layout_width="10dp"
            android:layout_height="18dp"
            android:layout_marginRight="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="30dp"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textSize="14dp"
            android:textColor="@color/recording_modify_default_content_text"
            android:id="@+id/fragment_setschedules_start_current_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="10dp"
            android:layout_toLeftOf="@+id/fragment_setschedules_start_arrow_img"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="10dp"
            android:layout_toStartOf="@+id/fragment_setschedules_start_arrow_img"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/fragment_setschedules_start_bottom_line"
        android:background="@color/recording_line_bg"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_alignParentBottom="true"/>
    <RelativeLayout
        android:id="@+id/fragment_setschedules_stop_rl"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <TextView
            android:textSize="14dp"
            android:textColor="@color/recording_item_text"
            android:id="@+id/fragment_setschedules_stop_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"/>
        <ImageView
            android:id="@+id/fragment_setschedules_stop_arrow_img"
            android:background="@drawable/mine_account_back"
            android:layout_width="10dp"
            android:layout_height="18dp"
            android:layout_marginRight="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="30dp"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textSize="14dp"
            android:textColor="@color/recording_modify_default_content_text"
            android:id="@+id/fragment_setschedules_stop_current_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="10dp"
            android:layout_toLeftOf="@+id/fragment_setschedules_stop_arrow_img"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="10dp"
            android:layout_toStartOf="@+id/fragment_setschedules_stop_arrow_img"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/fragment_setschedules_stop_bottom_line"
        android:background="@color/recording_line_bg"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_alignParentBottom="true"/>
    <RelativeLayout
        android:id="@+id/fragment_setschedules_keepuntil_rl"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <TextView
            android:textSize="14dp"
            android:textColor="@color/recording_item_text"
            android:id="@+id/fragment_setschedules_keepuntil_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"/>
        <ImageView
            android:id="@+id/fragment_setschedules_keepuntil_arrow_img"
            android:background="@drawable/mine_account_back"
            android:layout_width="10dp"
            android:layout_height="18dp"
            android:layout_marginRight="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="30dp"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textSize="14dp"
            android:textColor="@color/recording_modify_default_content_text"
            android:id="@+id/fragment_setschedules_keepuntil_current_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="10dp"
            android:layout_toLeftOf="@+id/fragment_setschedules_keepuntil_arrow_img"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="10dp"
            android:layout_toStartOf="@+id/fragment_setschedules_keepuntil_arrow_img"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/fragment_setschedules_keepuntil_bottom_line"
        android:background="@color/recording_line_bg"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_alignParentBottom="true"/>
</LinearLayout>
