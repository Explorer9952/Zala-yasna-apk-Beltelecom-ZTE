<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/setting_title_grey"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/title_rlayout"
        android:background="@color/title_bar_bg"
        android:layout_width="match_parent"
        android:layout_height="52dp">
        <Button
            android:id="@+id/btn_back"
            android:background="@drawable/title_back_bg"
            android:layout_width="43dp"
            android:layout_height="52dp"/>
        <TextView
            android:textSize="20sp"
            android:textColor="@color/title_bar_text_color"
            android:id="@+id/title_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/title_bottom_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:src="@color/divider_line_grey"/>
    <LinearLayout
        android:id="@+id/ll_blank1"
        android:background="@color/setting_title_grey"
        android:layout_width="match_parent"
        android:layout_height="52dp">
        <TextView
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/bottom_line1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:src="@color/divider_line_grey"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/WHITE"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rl_statement_conditions"
            android:background="@color/WHITE"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/text_grey_new1"
                android:id="@+id/txt_statement_conditions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"/>
            <ImageView
                android:id="@+id/statement_conditions_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/arrow"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <ImageView
            android:id="@+id/bottom_line2"
            android:paddingLeft="10dp"
            android:paddingRight="0dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:src="@color/divider_line_grey"
            android:paddingStart="10dp"
            android:paddingEnd="0dp"/>
        <RelativeLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rl_faqs"
            android:background="@color/WHITE"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/text_grey_new1"
                android:id="@+id/txt_faqs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"/>
            <ImageView
                android:id="@+id/faqs_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/arrow"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <ImageView
            android:id="@+id/bottom_line3"
            android:paddingLeft="10dp"
            android:paddingRight="0dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:src="@color/divider_line_grey"
            android:paddingStart="10dp"
            android:paddingEnd="0dp"/>
        <RelativeLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rl_customer_feedback"
            android:background="@color/WHITE"
            android:paddingLeft="18dp"
            android:paddingRight="10dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="18dp"
            android:paddingEnd="10dp">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/text_grey_new1"
                android:id="@+id/txt_customer_feedback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"/>
            <ImageView
                android:id="@+id/customer_feedback_arrow"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/enter_into_menue_item_bg"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <ImageView
        android:id="@+id/bottom_line4"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:src="@color/divider_line_grey"/>
    <LinearLayout
        android:id="@+id/ll_blank2"
        android:background="@color/setting_title_grey"
        android:layout_width="match_parent"
        android:layout_height="52dp">
        <TextView
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/bottom_line5"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:src="@color/divider_line_grey"/>
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/WHITE"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rl_about"
            android:background="@color/WHITE"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/text_grey_new1"
                android:id="@+id/txt_about"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"/>
            <ImageView
                android:id="@+id/about_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/arrow"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <ImageView
            android:id="@+id/bottom_line6"
            android:paddingLeft="10dp"
            android:paddingRight="0dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:src="@color/divider_line_grey"
            android:paddingStart="10dp"
            android:paddingEnd="0dp"/>
        <RelativeLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/rl_version"
            android:background="@color/WHITE"
            android:paddingLeft="18dp"
            android:paddingRight="10dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="18dp"
            android:paddingEnd="10dp">
            <TextView
                android:textSize="16sp"
                android:textColor="@color/text_grey_new1"
                android:id="@+id/txt_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/text_grey_new1"
                android:id="@+id/txt_version_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="7dp"
                android:layout_toLeftOf="@+id/version_arrow"
                android:layout_centerVertical="true"
                android:layout_marginEnd="7dp"
                android:layout_toStartOf="@+id/version_arrow"/>
            <ImageView
                android:id="@+id/version_arrow"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/enter_into_menue_item_bg"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <ImageView
        android:id="@+id/bottom_line7"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:src="@color/divider_line_grey"/>
</LinearLayout>
