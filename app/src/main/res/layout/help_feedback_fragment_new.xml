<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/ll_container"
    android:background="@color/mine_feedback_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/home_top_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <include layout="@layout/common_header_level_two"/>
    <EditText
        android:textSize="18dp"
        android:textColor="@color/mine_feedback_text_textcolor"
        android:textColorHint="@color/mine_feedback_text_textcolor"
        android:gravity="start|top"
        android:id="@+id/msg_edittext"
        android:background="@drawable/feedback_edittext_bg"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginRight="20dp"
        android:hint="@string/feedback_hint_o"
        android:lineSpacingMultiplier="1.2"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        skin:enable="true"/>
    <EditText
        android:textColor="@color/mine_feedback_text_textcolor"
        android:textColorHint="@color/mine_feedback_text_textcolor"
        android:gravity="center_vertical"
        android:id="@+id/phone_edit"
        android:background="@drawable/feedback_edittext_bg"
        android:paddingLeft="10dp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="30dp"
        android:layout_marginRight="20dp"
        android:hint="@string/feedback_hint_t"
        android:singleLine="true"
        android:paddingStart="10dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        skin:enable="true"/>
    <Button
        android:textSize="18dp"
        android:textColor="@color/mine_feedback_confirm_textcolor"
        android:id="@+id/btn_commit"
        android:background="@drawable/feedback_commit_unnomal"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="60dp"
        android:layout_marginRight="20dp"
        android:textAllCaps="false"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        skin:enable="true"/>
</LinearLayout>
