<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/home_video_item_fl"
        android:layout_width="132dp"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:id="@+id/rl_time"
            android:layout_width="match_parent"
            android:layout_height="40dp">
            <View
                android:background="@color/menulinecolorex"
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="18dp"
                android:textColor="@color/account_text_color"
                android:gravity="center"
                android:id="@+id/txt_time"
                android:background="@color/white"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:layout_gravity="center_horizontal"
            android:id="@+id/img_rlayout"
            android:layout_width="122dp"
            android:layout_height="175dp">
            <ImageView
                android:id="@+id/poster_img"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/default_poster_thumb"
                android:scaleType="fitXY"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/txt_subscribe"
                android:background="@drawable/online_order_bg"
                android:layout_width="match_parent"
                android:layout_height="25dp"/>
        </RelativeLayout>
        <TextView
            android:textSize="18dp"
            android:textColor="@color/account_text_color"
            android:ellipsize="end"
            android:id="@+id/title_txt"
            android:paddingLeft="3dp"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:singleLine="true"
            android:lineSpacingMultiplier="1.4"
            android:paddingStart="3dp"/>
    </LinearLayout>
</LinearLayout>
