<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:skin="http://schemas.android.com/android/skin"
    android:id="@+id/home_video_item_cl"
    android:layout_width="@dimen/dimen_vod_poster_thumb_width"
    android:layout_height="wrap_content"
    skin:enable="true">
    <RelativeLayout
        android:id="@+id/img_rlayout"
        android:layout_width="@dimen/dimen_vod_poster_thumb_width"
        android:layout_height="@dimen/dimen_vod_poster_thumb_height"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/poster_img"
            android:layout_width="@dimen/dimen_vod_poster_thumb_width"
            android:layout_height="@dimen/dimen_vod_poster_thumb_height"
            android:src="@drawable/default_poster_thumb"
            android:scaleType="fitXY"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/img_corner"
            android:visibility="gone"
            android:layout_width="@dimen/corner_width"
            android:layout_height="@dimen/corner_height"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"/>
        <RelativeLayout
            android:id="@+id/rating_rl"
            android:background="@color/home_more_poster_bg"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_alignParentBottom="true"
            skin:enable="true">
            <TextView
                android:textSize="@dimen/common_title_bar_textsize"
                android:textColor="@color/home_recommend_rating_textcolor"
                android:id="@+id/rating_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
        </RelativeLayout>
        <ImageView
            android:id="@+id/ivi_logo_top"
            android:visibility="gone"
            android:layout_width="27.2dp"
            android:layout_height="20dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/ivi_logo"
            android:layout_alignParentRight="true"
            android:layout_marginEnd="5dp"/>
    </RelativeLayout>
    <TextView
        android:textSize="@dimen/poster_video_title_textsize"
        android:textColor="@color/home_more_postertitle_bg"
        android:ellipsize="end"
        android:layout_gravity="bottom"
        android:id="@+id/title_txt"
        android:visibility="visible"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:paddingStart="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/img_rlayout"
        skin:enable="true"/>
    <TextView
        android:textSize="@dimen/poster_video_subtitle_textsize"
        android:textColor="@color/home_column_title_erji"
        android:ellipsize="end"
        android:layout_gravity="bottom"
        android:id="@+id/title_txt_fu"
        android:visibility="visible"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:paddingStart="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_txt"
        skin:enable="true"/>
</androidx.constraintlayout.widget.ConstraintLayout>
