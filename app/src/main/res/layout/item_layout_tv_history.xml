<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/rl_content"
    android:background="@color/mine_bg"
    android:layout_width="match_parent"
    android:layout_height="108dp"
    skin:enable="true">
    <ImageView
        android:id="@+id/iv_select"
        android:background="@drawable/favorite_video_select"
        android:visibility="gone"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:layout_alignParentStart="true"/>
    <ImageView
        android:id="@+id/iv_poster"
        android:background="@color/channel_background"
        android:layout_width="80dp"
        android:layout_height="60dp"
        android:layout_marginTop="26dp"
        android:scaleType="fitXY"
        android:layout_marginStart="20dp"
        android:layout_toEndOf="@+id/iv_select"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/history_channel_info"
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginStart="15dp"
        android:layout_toEndOf="@+id/iv_poster"
        skin:enable="true"/>
    <TextView
        android:textSize="16sp"
        android:textColor="@color/history_channel_info"
        android:gravity="center"
        android:id="@+id/tv_channel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginStart="105dp"
        android:layout_toEndOf="@+id/iv_poster"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/iv_now"
        android:background="@drawable/icon_now"
        android:layout_width="34dp"
        android:layout_height="18dp"
        android:layout_marginTop="61dp"
        android:layout_marginBottom="31dp"
        android:layout_marginStart="15dp"
        android:layout_toEndOf="@+id/iv_poster"
        skin:enable="true"/>
    <TextView
        android:textSize="18sp"
        android:textColor="@color/history_prevue"
        android:id="@+id/tv_programme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="58dp"
        android:layout_marginBottom="25dp"
        android:singleLine="true"
        android:layout_marginStart="52dp"
        android:layout_marginEnd="11dp"
        android:layout_toEndOf="@+id/iv_poster"
        skin:enable="true"/>
</RelativeLayout>
