<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/ll_item_season_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="@dimen/vod_detail_title_textsize"
        android:textColor="@color/series_season_item_style"
        android:ellipsize="end"
        android:layout_gravity="bottom"
        android:id="@+id/season_title_num_txt"
        android:paddingLeft="3dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="7dp"
        android:text="Season 1"
        android:maxLines="1"
        android:paddingStart="3dp"/>
    <RelativeLayout
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_season_poster_thumb"
            android:layout_width="@dimen/dimen_vod_poster_thumb_width"
            android:layout_height="@dimen/dimen_vod_poster_thumb_height"
            android:src="@drawable/default_poster_thumb"
            android:scaleType="fitXY"/>
        <ImageView
            android:id="@+id/ivi_logo_top"
            android:visibility="gone"
            android:layout_width="27.2dp"
            android:layout_height="20dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/ivi_logo"
            android:layout_alignParentRight="true"
            android:layout_marginEnd="5dp"/>
    </RelativeLayout>
    <TextView
        android:textSize="@dimen/vod_detail_title_textsize"
        android:textColor="@color/series_season_item_style"
        android:ellipsize="end"
        android:layout_gravity="bottom"
        android:id="@+id/season_title_name_txt"
        android:paddingLeft="3dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="7dp"
        android:text="The Marvelous Mrs.Maisel 01"
        android:maxLines="2"
        android:paddingStart="3dp"/>
</LinearLayout>
