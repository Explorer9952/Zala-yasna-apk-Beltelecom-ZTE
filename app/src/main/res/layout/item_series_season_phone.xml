<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_item_season_container"
        android:paddingLeft="10dp"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:paddingStart="10dp">
        <TextView
            android:textSize="@dimen/vod_detail_title_textsize"
            android:textColor="@color/series_season_item_style"
            android:ellipsize="end"
            android:layout_gravity="bottom"
            android:id="@+id/season_title_num_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="7dp"
            android:text="Season 1"
            android:maxLines="1"/>
        <ImageView
            android:id="@+id/iv_season_poster_thumb"
            android:layout_width="@dimen/dimen_season_item_poster_thumb_width"
            android:layout_height="@dimen/dimen_season_item_poster_thumb_height"
            android:src="@drawable/default_poster_thumb"
            android:scaleType="fitXY"/>
        <TextView
            android:textSize="@dimen/vod_detail_title_textsize"
            android:textColor="@color/series_season_item_style"
            android:ellipsize="end"
            android:layout_gravity="bottom"
            android:id="@+id/season_title_name_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="7dp"
            android:text="The Marvelous Mrs.Maisel 01"
            android:maxLines="2"/>
    </LinearLayout>
</LinearLayout>
