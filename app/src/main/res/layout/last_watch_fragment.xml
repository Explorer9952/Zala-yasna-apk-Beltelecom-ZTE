<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:background="@color/mine_record_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/mine_record_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/rl_last_watch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/top">
        <RelativeLayout
            android:id="@+id/rl_title"
            android:background="@color/mine_record_title_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mine_fragment_myaccount_ll_height"
            skin:enable="true">
            <Button
                android:id="@+id/btn_back"
                android:background="@drawable/title_back_bg"
                android:visibility="gone"
                android:layout_width="43dp"
                android:layout_height="52dp"
                android:layout_centerVertical="true"
                skin:enable="true"/>
            <TextView
                android:textSize="@dimen/title_textsize"
                android:textColor="@color/mine_record_title_textcolor"
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                skin:enable="true"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/ll_edit"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true">
                <TextView
                    android:textSize="20sp"
                    android:textColor="@color/mine_record_menu_textcolor"
                    android:id="@+id/tv_edit"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="15dp"
                    skin:enable="true"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/iv_edit"
                    android:background="@drawable/title_edit_style"
                    android:visibility="gone"
                    android:layout_width="43dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="15dp"
                    skin:enable="true"/>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl_edit"
            android:background="@color/mine_record_bg"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="63dp"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            skin:enable="true">
            <TextView
                android:textSize="20sp"
                android:textColor="@color/mine_record_edittext_textcolor"
                android:id="@+id/tv_select_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                skin:enable="true"/>
            <TextView
                android:textSize="20sp"
                android:textColor="@color/mine_record_edittext_textcolor"
                android:id="@+id/tv_select_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                skin:enable="true"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@+id/ll_cancel_edit"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true">
                <TextView
                    android:textSize="20sp"
                    android:textColor="@color/mine_record_edittext_textcolor"
                    android:id="@+id/tv_cancel_edit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="15dp"
                    skin:enable="true"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
    <ImageView
        android:id="@+id/iv_line"
        android:background="@color/mine_record_separate_bg"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_below="@+id/rl_last_watch"
        android:contentDescription="@string/content_description"
        skin:enable="true"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/iv_line">
        <com.scwang.smartrefresh.layout.SmartRefreshLayout
            android:id="@+id/refreshLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/title_bottom_line">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <com.zte.iptvclient.android.common.customview.viewgroup.scrollview.ScrollViewEx
                    android:layout_gravity="center"
                    android:id="@+id/scHomeFragmentContent"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/fl_container"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </com.zte.iptvclient.android.common.customview.viewgroup.scrollview.ScrollViewEx>
                <include layout="@layout/empty_pull_refresh_view"/>
            </RelativeLayout>
        </com.scwang.smartrefresh.layout.SmartRefreshLayout>
        <FrameLayout
            android:id="@+id/fl_delete"
            android:background="@color/mine_record_delete_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_alignParentBottom="true"
            skin:enable="true">
            <LinearLayout
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/iv_delete"
                    android:background="@drawable/myfav_action_delete"
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    skin:enable="true"/>
                <TextView
                    android:textSize="20sp"
                    android:textColor="@color/mine_record_delete_textcolor"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tv_delete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    skin:enable="true"/>
            </LinearLayout>
        </FrameLayout>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/rl_loading"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/rl_last_watch">
        <ImageView
            android:id="@+id/iv_animation_loading"
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:src="@drawable/frame_loading_animlist_new"
            android:layout_centerInParent="true"
            skin:enable="true"/>
    </RelativeLayout>
</RelativeLayout>
