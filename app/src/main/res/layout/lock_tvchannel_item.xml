<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/parental_control_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_tv_lock_item"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/tv_lock_selector"
            android:visibility="gone"
            android:layout_width="26.67dp"
            android:layout_height="26.67dp"
            android:src="@drawable/unselect_new"
            android:layout_marginStart="17.33dp"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/tv_lock_icon"
            android:background="@color/white"
            android:layout_width="72dp"
            android:layout_height="54dp"
            android:paddingStart="22.67dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/tv_lock_rightll"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="14.67dp">
            <RelativeLayout
                android:orientation="horizontal"
                android:id="@+id/tv_lock_contentll"
                android:layout_width="wrap_content"
                android:layout_height="62dp">
                <TextView
                    android:textColor="@color/parental_control_text_initial_color"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/lock_tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:maxLines="1"
                    android:maxEms="12"
                    skin:enable="true"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/lock_img"
                    android:background="@drawable/menu_more_lock_normal"
                    android:visibility="invisible"
                    android:layout_width="35dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentEnd="true"
                    skin:enable="true"/>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        android:background="@color/common_separateline_color"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        skin:enable="true"/>
</LinearLayout>
