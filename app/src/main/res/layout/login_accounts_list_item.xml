<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/rl_accounts_layout"
        android:background="@color/login_accounts_list_bg"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        skin:enable="true">
        <TextView
            android:textSize="18sp"
            android:textColor="@color/login_accounts_list_textcolor"
            android:ellipsize="end"
            android:id="@+id/txt_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/img_clear_accounts"
            android:background="@drawable/input_clear_style"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginRight="10dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
    </RelativeLayout>
</LinearLayout>
