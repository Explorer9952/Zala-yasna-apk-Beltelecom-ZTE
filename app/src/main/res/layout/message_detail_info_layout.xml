<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/mine_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/mine_setting_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <include layout="@layout/header_general_back"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="35dp"
            android:layout_marginRight="35dp"
            android:layout_marginStart="35dp"
            android:layout_marginEnd="35dp">
            <TextView
                android:textSize="27sp"
                android:textColor="@color/text_main_title"
                android:ellipsize="end"
                android:id="@+id/main_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:maxEms="2"
                skin:enable="true"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp">
                <TextView
                    android:textSize="18sp"
                    android:textColor="@color/mine_message_listitem_content"
                    android:ellipsize="end"
                    android:id="@+id/msg_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="80dp"
                    android:singleLine="true"
                    android:layout_marginEnd="80dp"
                    skin:enable="true"/>
                <TextView
                    android:textSize="18sp"
                    android:textColor="@color/mine_message_listitem_content"
                    android:ellipsize="end"
                    android:id="@+id/msg_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentEnd="true"
                    skin:enable="true"/>
            </RelativeLayout>
            <TextView
                android:textSize="19sp"
                android:textColor="@color/mine_message_listitem_title"
                android:id="@+id/msg_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="42dp"
                android:lineSpacingMultiplier="2"
                skin:enable="true"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
