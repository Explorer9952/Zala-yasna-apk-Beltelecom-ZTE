<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/pop_view_series_epsiode"
    android:background="@color/movie_series_more_bg"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <include layout="@layout/common_detail_view_title"/>
    <include layout="@layout/common_detail_view_title_samll"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <it.sephiroth.android.library.widget.HListView
                android:orientation="horizontal"
                android:id="@+id/navigation_hlistview"
                android:scrollbars="none"
                android:fadingEdge="horizontal"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginLeft="15dp"
                android:listSelector="#00000000"
                android:layout_marginStart="15dp"/>
            <com.zte.iptvclient.android.common.customview.viewgroup.gridview.ScrollGridView
                android:gravity="center"
                android:id="@+id/episode_gvew"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="15dp"
                android:layout_marginBottom="10dp"
                android:listSelector="#00000000"
                android:horizontalSpacing="5dp"
                android:verticalSpacing="5dp"
                android:stretchMode="columnWidth"
                android:numColumns="6"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_multiscreen_program_edit_view"
                android:background="@color/search_view_main_theme_color"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                skin:enable="true">
                <View
                    android:background="@color/common_separateline_color"
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    skin:enable="true"/>
                <include layout="@layout/multiscreen_program_edit"/>
                <View
                    android:background="@color/common_separateline_color"
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    skin:enable="true"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
