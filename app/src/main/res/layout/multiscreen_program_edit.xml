<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:id="@+id/ll_program_edit_main"
    android:layout_width="match_parent"
    android:layout_height="60dp">
    <GridView
        android:layout_gravity="center_vertical"
        android:id="@+id/gv_program_edit"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:numColumns="4"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"/>
    <TextView
        android:textSize="18dp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/txt_ok"
        android:background="@color/multiplayer_editbutton_bg"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:layout_marginRight="10dp"
        android:layout_marginEnd="10dp"
        skin:enable="true"/>
</LinearLayout>
