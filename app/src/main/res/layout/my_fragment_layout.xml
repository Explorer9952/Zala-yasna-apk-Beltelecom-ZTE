<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_phone"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/vod_detail_comment_bg"
        skin:enable="true"
        style="@style/top_bar"/>
    <RelativeLayout
        android:id="@+id/rl_title_layout"
        android:background="@color/vod_detail_comment_bg"
        android:layout_width="match_parent"
        android:layout_height="70dp">
        <TextView
            android:textSize="20dp"
            android:textColor="@color/account_textcolor"
            android:id="@+id/my_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <include
        android:id="@+id/recording_layout"
        layout="@layout/common_mine_img_txt_arrow_layout"/>
    <include
        android:id="@+id/favorites_layout"
        layout="@layout/common_mine_img_txt_arrow_layout"/>
    <include
        android:id="@+id/last_watch_layout"
        layout="@layout/common_mine_img_txt_arrow_layout"/>
    <View
        android:id="@+id/view_devided"
        android:background="@color/mine_separation_line_bg"
        android:layout_width="match_parent"
        android:layout_height="18dp"/>
    <RelativeLayout
        android:id="@+id/rl_balance"
        android:layout_width="match_parent"
        android:layout_height="70dp">
        <ImageView
            android:id="@+id/img_balance"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/mine_balance"
            android:layout_centerVertical="true"
            android:layout_marginStart="23dp"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="@dimen/common_14_px"
            android:textColor="@color/mine_title_textcolor"
            android:id="@+id/txt_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@+id/img_balance"
            android:layout_centerVertical="true"
            android:layout_marginStart="15dp"
            android:layout_toEndOf="@+id/img_balance"
            skin:enable="true"/>
        <TextView
            android:textSize="@dimen/common_14_px"
            android:textColor="@color/balance_txt"
            android:id="@+id/txt_account_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="30dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="30dp"
            android:layout_alignParentEnd="true"/>
        <View
            android:id="@+id/buttom_view_line"
            android:background="@color/mine_separation_line_bg"
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_alignParentBottom="true"/>
    </RelativeLayout>
    <include
        android:id="@+id/ppv_layout"
        layout="@layout/common_mine_img_txt_arrow_layout"/>
    <include
        android:id="@+id/packages_layout"
        layout="@layout/common_mine_img_txt_arrow_layout"/>
    <include
        android:id="@+id/purchase_layout"
        layout="@layout/common_mine_img_txt_arrow_layout"/>
</LinearLayout>
