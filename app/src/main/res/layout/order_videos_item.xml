<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:layout_gravity="center"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:layout_gravity="center"
        android:id="@+id/home_video_item_fl"
        android:layout_width="148dp"
        android:layout_height="247dp">
        <RelativeLayout
            android:gravity="center"
            android:id="@+id/img_rlayout"
            android:background="@color/transparent"
            android:layout_width="148dp"
            android:layout_height="212dp">
            <ImageView
                android:id="@+id/poster_img"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/default_poster_thumb"
                android:scaleType="fitXY"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/tv_icon"
                android:background="@color/white"
                android:layout_width="148dp"
                android:layout_height="88dp"
                android:layout_marginTop="35dp"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"/>
            <ImageView
                android:id="@+id/img_corner"
                android:visibility="gone"
                android:layout_width="@dimen/corner_width"
                android:layout_height="@dimen/corner_height"
                android:layout_alignParentTop="true"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true"/>
            <RelativeLayout
                android:id="@+id/rating_rl"
                android:background="@color/home_recommend_rating_bg"
                android:visibility="invisible"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_alignParentBottom="true"
                skin:enable="true">
                <TextView
                    android:textSize="@dimen/common_title_bar_textsize"
                    android:textColor="@color/vod_dark_textcolor"
                    android:id="@+id/rating_txt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    skin:enable="true"/>
            </RelativeLayout>
        </RelativeLayout>
        <TextView
            android:textSize="18dp"
            android:textColor="@color/home_video_title_textcolor"
            android:ellipsize="end"
            android:layout_gravity="bottom"
            android:id="@+id/title_txt"
            android:paddingLeft="3dp"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="7dp"
            android:singleLine="true"
            android:paddingStart="3dp"
            skin:enable="true"/>
    </FrameLayout>
</FrameLayout>
