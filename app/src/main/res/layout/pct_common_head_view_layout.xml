<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:skin="http://schemas.android.com/android/skin"
    android:id="@+id/common_column_header_rlayout"
    android:paddingLeft="8dp"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginTop="10dp"
    android:paddingStart="8dp">
    <ImageView
        android:id="@+id/column_img"
        android:background="@color/home_video_title_textcolor"
        android:layout_width="2dp"
        android:layout_height="12dp"
        android:layout_marginLeft="10dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        skin:enable="true"/>
    <TextView
        android:textSize="@dimen/common_14_px"
        android:textColor="@color/home_columnhead_title_textcolor"
        android:ellipsize="end"
        android:id="@+id/column_title_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:maxLines="1"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/column_img"
        app:layout_constraintTop_toTopOf="parent"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/lock_tips"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:src="@drawable/vod_lock_3_level"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/column_title_txt"
        app:layout_constraintTop_toTopOf="parent"/>
    <RelativeLayout
        android:id="@+id/rl_next_all"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/more_icon"
            android:background="@drawable/home_more_arrow_normal"
            android:layout_width="10dp"
            android:layout_height="15dp"
            android:layout_marginRight="8dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
        <TextView
            android:textSize="@dimen/common_12_px"
            android:textColor="@color/home_columnhead_more_textcolor"
            android:ellipsize="end"
            android:id="@+id/more_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:maxLines="1"
            android:layout_toLeftOf="@+id/more_icon"
            android:layout_centerVertical="true"
            android:foregroundGravity="center_vertical"
            android:layout_marginEnd="10dp"
            skin:enable="true"/>
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
