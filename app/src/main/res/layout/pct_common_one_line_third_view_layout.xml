<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:skin="http://schemas.android.com/android/skin"
    android:id="@+id/common_first_third_view_layout"
    android:paddingLeft="4dp"
    android:paddingTop="4dp"
    android:paddingRight="4dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/commend_content_1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintEnd_toStartOf="@+id/commend_content_2"
        app:layout_constraintStart_toStartOf="parent">
        <ImageView
            android:id="@+id/commend_image_1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="fitXY"
            app:layout_constraintDimensionRatio="W,290:202"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <ImageView
            android:id="@+id/img_pay_free_1"
            android:visibility="gone"
            android:layout_width="55dp"
            android:layout_height="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/common_title_bar_textsize"
            android:textColor="@color/white"
            android:gravity="end|center_vertical"
            android:id="@+id/series_lastupdate_txt_1"
            android:background="@drawable/bg_lastupdate"
            android:padding="5dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:layout_constraintBottom_toBottomOf="@+id/commend_image_1"
            app:layout_constraintEnd_toEndOf="parent"/>
        <TextView
            android:textSize="@dimen/vod_detail_title_textsize"
            android:textColor="@color/home_column_title"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/commend_name_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lineSpacingMultiplier="1.4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/commend_image_1"
            skin:enable="true"/>
        <TextView
            android:textSize="@dimen/vod_detail_subtitle_textsize"
            android:textColor="@color/home_column_title_erji"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/commend_short_name_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lineSpacingMultiplier="1.2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/commend_name_1"
            skin:enable="true"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/commend_content_2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintEnd_toStartOf="@+id/commend_content_3"
        app:layout_constraintStart_toEndOf="@+id/commend_content_1">
        <ImageView
            android:id="@+id/commend_image_2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="fitXY"
            app:layout_constraintDimensionRatio="W,290:202"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <ImageView
            android:id="@+id/img_pay_free_2"
            android:visibility="gone"
            android:layout_width="55dp"
            android:layout_height="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/common_title_bar_textsize"
            android:textColor="@color/white"
            android:gravity="end|center_vertical"
            android:id="@+id/series_lastupdate_txt_2"
            android:background="@drawable/bg_lastupdate"
            android:padding="5dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:layout_constraintBottom_toBottomOf="@+id/commend_image_2"
            app:layout_constraintEnd_toEndOf="parent"/>
        <TextView
            android:textSize="@dimen/vod_detail_title_textsize"
            android:textColor="@color/home_column_title"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/commend_name_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lineSpacingMultiplier="1.4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/commend_image_2"
            skin:enable="true"/>
        <TextView
            android:textSize="@dimen/vod_detail_subtitle_textsize"
            android:textColor="@color/home_column_title_erji"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/commend_short_name_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lineSpacingMultiplier="1.2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/commend_name_2"
            skin:enable="true"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/commend_content_3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/commend_content_2">
        <ImageView
            android:id="@+id/commend_image_3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="fitXY"
            app:layout_constraintDimensionRatio="W,290:202"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <ImageView
            android:id="@+id/img_pay_free_3"
            android:visibility="gone"
            android:layout_width="55dp"
            android:layout_height="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/common_title_bar_textsize"
            android:textColor="@color/white"
            android:gravity="end|center_vertical"
            android:id="@+id/series_lastupdate_txt_3"
            android:background="@drawable/bg_lastupdate"
            android:padding="5dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:layout_constraintBottom_toBottomOf="@+id/commend_image_3"
            app:layout_constraintEnd_toEndOf="parent"/>
        <TextView
            android:textSize="@dimen/vod_detail_title_textsize"
            android:textColor="@color/home_column_title"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/commend_name_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lineSpacingMultiplier="1.4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/commend_image_3"
            skin:enable="true"/>
        <TextView
            android:textSize="@dimen/vod_detail_subtitle_textsize"
            android:textColor="@color/home_column_title_erji"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/commend_short_name_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lineSpacingMultiplier="1.2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/commend_name_3"
            skin:enable="true"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
