        <TextView
            android:textSize="@dimen/common_title_bar_textsize"
            android:textColor="@color/white"
            android:gravity="end|center_vertical"
            android:id="@+id/series_lastupdate_txt_6"
            android:background="@drawable/bg_lastupdate"
            android:padding="5dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:layout_constraintBottom_toBottomOf="@+id/commend_image_6"
            app:layout_constraintRight_toRightOf="parent"/>
        <TextView
            android:textSize="@dimen/vod_detail_title_textsize"
            android:textColor="@color/home_column_title"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/commend_name_6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
