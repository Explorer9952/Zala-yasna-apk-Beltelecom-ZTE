<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/common_second_third_view_layout"
    android:paddingLeft="4dp"
    android:paddingTop="4dp"
    android:paddingRight="4dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/commend_content_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintEnd_toStartOf="@+id/commend_content_5"
        app:layout_constraintStart_toStartOf="parent">
        <ImageView
            android:id="@+id/commend_image_4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="fitXY"
            app:layout_constraintDimensionRatio="W,290:202"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>
        <ImageView
            android:id="@+id/img_pay_free_4"
            android:visibility="gone"
            android:layout_width="55dp"
            android:layout_height="20dp"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/common_title_bar_textsize"
            android:textColor="@color/white"
            android:gravity="end|center_vertical"
            android:id="@+id/series_lastupdate_txt_4"
            android:background="@drawable/bg_lastupdate"
            android:padding="5dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:layout_constraintBottom_toBottomOf="@+id/commend_image_4"
            app:layout_constraintRight_toRightOf="parent"/>
        <TextView
            android:textSize="@dimen/vod_detail_title_textsize"
            android:textColor="@color/home_column_title"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/commend_name_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lineSpacingMultiplier="1.4"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/commend_image_4"
            skin:enable="true"/>
        <TextView
            android:textSize="@dimen/vod_detail_subtitle_textsize"
            android:textColor="@color/home_column_title_erji"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/commend_short_name_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lineSpacingMultiplier="1.2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/commend_name_4"
            skin:enable="true"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
