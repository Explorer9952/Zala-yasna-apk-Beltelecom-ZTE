<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/rlayout_player_stb"
        android:background="@drawable/player_stb_select_bg"
        android:layout_width="170dp"
        android:layout_height="170dp">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/refresh_llayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true">
            <ImageView
                android:id="@+id/btn_refresh"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginRight="5dp"
                android:layout_marginEnd="5dp"/>
            <TextView
                android:textSize="15dp"
                android:textColor="@drawable/player_scan_txt_style2"
                android:id="@+id/txt_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <ListView
            android:id="@+id/listvew_player_stb"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:listSelector="#00000000"
            android:cacheColorHint="#00000000"
            android:divider="@null"
            android:layout_above="@+id/refresh_llayout"/>
    </RelativeLayout>
</RelativeLayout>
