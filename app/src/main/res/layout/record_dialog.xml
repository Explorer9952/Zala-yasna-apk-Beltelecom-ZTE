<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/commont_dialog_margen_value"
        android:layout_marginEnd="@dimen/commont_dialog_margen_value">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/comm_dialog_title_parent"
            android:background="@drawable/order_dialog_connent_bg"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/comm_dialog_icon"
                android:visibility="gone"
                android:layout_width="25dp"
                android:layout_height="25dp"/>
            <TextView
                android:textSize="18dp"
                android:textColor="@color/dialog_text"
                android:gravity="center"
                android:id="@+id/comm_dialog_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="15dp"
                android:minHeight="120dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/comm_dialog_content"
                android:padding="15dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>
        </LinearLayout>
        <View
            android:id="@+id/line"
            android:background="@color/dialog_devide"
            android:layout_width="match_parent"
            android:layout_height="1px"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/comm_dialog_bottom"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <Button
                android:textSize="18dp"
                android:textColor="@color/dialog_btn_txt_bg"
                android:id="@+id/comm_dialog_negative_button"
                android:background="@drawable/order_dialog_bottonleft_bg"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:textAllCaps="false"/>
            <View
                android:id="@+id/devider_positive_negative"
                android:background="@color/dialog_devide"
                android:visibility="gone"
                android:layout_width="1px"
                android:layout_height="match_parent"/>
            <Button
                android:textSize="18dp"
                android:textColor="@color/dialog_btn_txt_bg"
                android:id="@+id/comm_dialog_positive_button"
                android:background="@drawable/order_dialog_bottonright_background"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:textAllCaps="false"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
