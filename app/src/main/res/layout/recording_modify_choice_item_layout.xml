<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/recording_item_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:orientation="horizontal"
        android:id="@+id/recording_modify_choice_item_rl"
        android:layout_width="wrap_content"
        android:layout_height="50dp">
        <TextView
            android:textSize="16dp"
            android:textColor="@color/recording_item_text"
            android:gravity="center_vertical"
            android:id="@+id/recording_modify_choice_item_txt"
            android:paddingLeft="20dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:maxLines="1"
            android:layout_alignParentLeft="true"
            android:paddingStart="20dp"
            android:layout_alignParentStart="true"/>
        <ImageView
            android:id="@+id/recording_modify_choice_select_img"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginRight="20dp"
            android:src="@drawable/icon_select"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="20dp"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <View
        android:background="@color/recording_line_bg"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@+id/recording_modify_choice_item_rl"/>
</RelativeLayout>
