<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@color/regist_bg"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/login_status_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <include layout="@layout/header_general_back"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_registaccount"
        android:background="@color/regist_bg"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        skin:enable="true">
        <TextView
            android:textSize="16dp"
            android:textColor="@color/regist_text_textcolor"
            android:id="@+id/txt_phonenum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            skin:enable="true"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <EditText
                android:textSize="16dp"
                android:textColor="@color/regist_text_textcolor"
                android:textColorHint="@color/regist_hint_textcolor"
                android:id="@+id/edt_phonenum"
                android:background="@drawable/input_bg_grey"
                android:paddingLeft="10dp"
                android:paddingRight="40dp"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:singleLine="true"
                android:digits="1234567890."
                android:layout_toRightOf="@+id/txt_phonenumhead"
                android:paddingStart="10dp"
                android:paddingEnd="40dp"
                android:layout_toEndOf="@+id/txt_phonenumhead"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/img_phonenum_clear"
                android:visibility="gone"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginRight="10dp"
                android:src="@drawable/input_clear_style"
                android:layout_alignRight="@+id/edt_phonenum"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:layout_alignEnd="@+id/edt_phonenum"
                skin:enable="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/regist_checkout_textcolor"
            android:id="@+id/txt_check_phonenum_result"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            skin:enable="true"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/regist_text_textcolor"
            android:id="@+id/txt_newpassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            skin:enable="true"/>
        <RelativeLayout
            android:id="@+id/ll_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <EditText
                android:textSize="16dp"
                android:textColor="@color/regist_text_textcolor"
                android:textColorHint="@color/regist_hint_textcolor"
                android:id="@+id/edt_new_password"
                android:background="@drawable/input_bg_grey"
                android:paddingLeft="11dp"
                android:paddingRight="40dp"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:singleLine="true"
                android:imeOptions="actionNext"
                android:paddingStart="11dp"
                android:paddingEnd="40dp"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/img_new_password_clear"
                android:visibility="gone"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginRight="10dp"
                android:src="@drawable/input_clear_style"
                android:layout_alignRight="@+id/edt_new_password"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:layout_alignEnd="@+id/edt_new_password"
                skin:enable="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/regist_checkout_textcolor"
            android:id="@+id/txt_check_newpassword_result"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            skin:enable="true"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/regist_text_textcolor"
            android:id="@+id/txt_confirm_newpassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            skin:enable="true"/>
        <RelativeLayout
            android:id="@+id/ll_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <EditText
                android:textSize="16dp"
                android:textColor="@color/regist_text_textcolor"
                android:textColorHint="@color/regist_hint_textcolor"
                android:id="@+id/edt_confirm_new_password"
                android:background="@drawable/input_bg_grey"
                android:paddingLeft="11dp"
                android:paddingRight="40dp"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:hint="@string/account_password_limit"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:paddingStart="11dp"
                android:paddingEnd="40dp"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/img_confirm_new_password_clear"
                android:visibility="gone"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginRight="10dp"
                android:src="@drawable/input_clear_style"
                android:layout_alignRight="@+id/edt_confirm_new_password"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:layout_alignEnd="@+id/edt_confirm_new_password"
                skin:enable="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/regist_checkout_textcolor"
            android:id="@+id/txt_check_confirm_newpassword_result"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            skin:enable="true"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_remember"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <ToggleButton
                android:layout_gravity="center_vertical"
                android:id="@+id/tg_remember"
                android:background="@drawable/setting_switch_selector"
                android:layout_width="70dp"
                android:layout_height="45dp"
                android:textOn=""
                android:textOff=""
                skin:enable="true"/>
            <TextView
                android:textSize="16dp"
                android:textColor="@color/regist_text_textcolor"
                android:layout_gravity="center_vertical"
                android:id="@+id/txt_agreement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginStart="12dp"
                skin:enable="true"/>
            <TextView
                android:textSize="16dp"
                android:textColor="@color/regist_text_textcolor"
                android:layout_gravity="center_vertical"
                android:id="@+id/txt_terms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginStart="5dp"
                skin:enable="true"/>
        </LinearLayout>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/ll_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp">
            <Button
                android:textSize="20dp"
                android:textColor="@color/regist_text_textcolor"
                android:layout_gravity="center_horizontal"
                android:id="@+id/btnNext"
                android:background="@color/mine_setting_title_bg"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                skin:enable="true"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
