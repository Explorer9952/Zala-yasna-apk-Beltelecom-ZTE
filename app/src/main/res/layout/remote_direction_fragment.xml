<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <Button
        android:id="@+id/btn_power_off"
        android:background="@drawable/remote_btn_power_bg"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="46dp"
        style="@style/stb_btn_style"
        skin:enable="true"/>
    <Button
        android:id="@+id/btn_playback"
        android:background="@drawable/remote_btn_playback_bg"
        android:visibility="gone"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerHorizontal="true"
        skin:enable="true"/>
    <Button
        android:id="@+id/btn_home"
        android:background="@drawable/remote_btn_home_bg"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerHorizontal="true"
        style="@style/stb_btn_style"
        skin:enable="true"/>
    <Button
        android:id="@+id/btn_mute"
        android:background="@drawable/remote_btn_mute_bg"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginEnd="46dp"
        android:layout_alignParentEnd="true"
        style="@style/stb_btn_style"
        skin:enable="true"/>
    <LinearLayout
        android:id="@+id/btn_title_fnume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_below="@+id/btn_power_off">
        <LinearLayout
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <Button
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/txt_f1"
                android:background="@color/remote_f1_textcolor"
                android:layout_width="60dp"
                android:layout_height="35dp"
                android:text="@string/f1"
                android:textAllCaps="false"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <Button
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/txt_f2"
                android:background="@color/remote_f2_textcolor"
                android:layout_width="60dp"
                android:layout_height="35dp"
                android:text="@string/f2"
                android:textAllCaps="false"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <Button
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/txt_f3"
                android:background="@color/remote_f3_textcolor"
                android:layout_width="60dp"
                android:layout_height="35dp"
                android:text="@string/f3"
                android:textAllCaps="false"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <Button
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/txt_f4"
                android:background="@color/remote_f4_textcolor"
                android:layout_width="60dp"
                android:layout_height="35dp"
                android:text="@string/f4"
                android:textAllCaps="false"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:layout_gravity="center"
        android:id="@+id/rl_remote_key"
        android:background="@drawable/remote_key_bg"
        android:visibility="gone"
        android:layout_width="320dp"
        android:layout_height="320dp"
        skin:enable="true">
        <Button
            android:id="@+id/btn_key_ok"
            android:background="@drawable/remote_key_ok_bg"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_centerInParent="true"
            skin:enable="true"/>
        <Button
            android:id="@+id/btn_key_right"
            android:background="@drawable/remote_key_right_bg"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="40dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
        <Button
            android:id="@+id/btn_key_left"
            android:background="@drawable/remote_key_left_bg"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="40dp"
            android:layout_alignParentStart="true"
            skin:enable="true"/>
        <Button
            android:id="@+id/btn_key_down"
            android:background="@drawable/remote_key_down_bg"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="40dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            skin:enable="true"/>
        <Button
            android:id="@+id/btn_key_up"
            android:background="@drawable/remote_key_up_bg"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="40dp"
            android:layout_centerHorizontal="true"
            skin:enable="true"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/txt_return"
        android:background="@drawable/remote_mobile_back"
        android:visibility="gone"
        android:layout_width="@dimen/remote_btn_round_height_width"
        android:layout_height="@dimen/remote_btn_round_height_width"
        android:layout_marginTop="15dp"
        android:layout_below="@+id/btn_power_off"
        android:layout_marginStart="46dp"
        skin:enable="true"/>
    <Button
        android:id="@+id/btn_volup"
        android:background="@drawable/remote_btn_volup_bg"
        android:layout_width="@dimen/remote_btn_round_height_width"
        android:layout_height="@dimen/remote_btn_round_height_width"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="46dp"
        skin:enable="true"/>
    <Button
        android:id="@+id/btn_playpause"
        android:background="@drawable/remote_btn_playpause_bg"
        android:layout_width="@dimen/remote_btn_round_height_width"
        android:layout_height="@dimen/remote_btn_round_height_width"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        skin:enable="true"/>
    <Button
        android:id="@+id/btn_voldown"
        android:background="@drawable/remote_btn_voldown_bg"
        android:layout_width="@dimen/remote_btn_round_height_width"
        android:layout_height="@dimen/remote_btn_round_height_width"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="46dp"
        android:layout_alignParentEnd="true"
        skin:enable="true"/>
    <Button
        android:id="@+id/btn_back"
        android:background="@drawable/remote_btn_back_bg"
        android:layout_width="@dimen/remote_btn_round_height_width"
        android:layout_height="@dimen/remote_btn_round_height_width"
        android:layout_above="@+id/btn_volup"
        android:layout_marginStart="46dp"
        skin:enable="true"/>
    <Button
        android:id="@+id/btn_menu"
        android:background="@drawable/remote_btn_menu_bg"
        android:layout_width="@dimen/remote_btn_round_height_width"
        android:layout_height="@dimen/remote_btn_round_height_width"
        android:layout_above="@+id/btn_voldown"
        android:layout_marginEnd="46dp"
        android:layout_alignParentEnd="true"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/rl_direction_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="5dp"
        android:layout_above="@+id/btn_menu"
        android:layout_below="@+id/btn_title_fnume">
        <include layout="@layout/remote_gesture_guide"/>
        <ImageView
            android:id="@+id/img_remote"
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:src="@drawable/remote_btn_ok_normal"
            android:scaleType="center"
            android:layout_centerInParent="true"
            skin:enable="true"/>
        <RelativeLayout
            android:id="@+id/rl_remote_change_mode"
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:layout_centerInParent="true">
            <ImageView
                android:id="@+id/img_remote_change_mode"
                android:visibility="gone"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/remote_btn_gesture"
                android:layout_alignParentTop="true"
                android:layout_marginEnd="20dp"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>
