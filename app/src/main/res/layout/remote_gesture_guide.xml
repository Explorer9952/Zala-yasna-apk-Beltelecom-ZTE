<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:layout_gravity="center"
    android:id="@+id/rl_gesture"
    android:visibility="gone"
    android:clickable="true"
    android:layout_width="400dp"
    android:layout_height="400dp"
    android:layout_centerInParent="true"
    skin:enable="true">
    <ImageView
        android:id="@+id/img_gester_up"
        android:paddingTop="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/remote_arrow_up"
        android:layout_centerHorizontal="true"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/img_gester_down"
        android:paddingBottom="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/remote_arrow_down"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/img_gester_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/remote_arrow_left"
        android:layout_centerVertical="true"
        android:paddingStart="10dp"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/img_gester_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/remote_arrow_right"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:paddingEnd="10dp"
        android:layout_alignParentEnd="true"
        skin:enable="true"/>
    <RelativeLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/ll_guide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <TextView
            android:textSize="18sp"
            android:textColor="@color/remote_hinttext_textcolor"
            android:id="@+id/tv_remote1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            skin:enable="true"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/remote_hinttext_textcolor"
            android:id="@+id/tv_remote2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="45dp"
            android:layout_below="@+id/tv_remote1"
            android:layout_centerHorizontal="true"
            skin:enable="true"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/img_hand"
        android:background="@drawable/remote_hand"
        android:visibility="gone"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginLeft="10dp"
        android:layout_toRightOf="@+id/ll_guide"
        android:layout_alignBottom="@+id/ll_guide"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/ll_guide"
        skin:enable="true"/>
</RelativeLayout>
