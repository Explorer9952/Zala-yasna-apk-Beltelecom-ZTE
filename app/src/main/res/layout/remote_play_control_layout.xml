<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <RelativeLayout
        android:id="@+id/ll_tv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_toEndOf="@+id/ll_play_control">
        <RelativeLayout
            android:orientation="vertical"
            android:id="@+id/rl_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="160dp">
            <ImageView
                android:id="@+id/img_tv"
                android:background="@drawable/remote_play_tv_en"
                android:layout_width="350dp"
                android:layout_height="210dp"
                android:layout_centerHorizontal="true"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/img_finger"
                android:background="@drawable/remote_playctl_hand"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginLeft="50dp"
                android:layout_below="@+id/img_tv"
                android:layout_marginStart="50dp"
                skin:enable="true"/>
            <TextView
                android:textSize="20sp"
                android:textColor="@color/remote_hinttext_textcolor"
                android:gravity="center_horizontal"
                android:id="@+id/textView1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="5dp"
                android:layout_below="@+id/img_finger"
                android:layout_centerHorizontal="true"
                skin:enable="true"/>
            <TextView
                android:textSize="20sp"
                android:textColor="@color/remote_hinttext_textcolor"
                android:gravity="center_horizontal"
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/textView1"
                skin:enable="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/remote_hinttext_textcolor"
            android:gravity="center_horizontal"
            android:id="@+id/tv_play_failed"
            android:padding="20dp"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:layout_below="@+id/rl_tv"
            skin:enable="true"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_btn"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tv_play_failed">
            <Button
                android:textSize="20sp"
                android:textColor="@color/remote_hinttext_textcolor"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/tv_return_phone"
                android:background="@drawable/remote_btn_play_back"
                android:layout_width="wrap_content"
                android:layout_height="65dp"
                skin:enable="true"/>
            <ImageView
                android:background="@drawable/remote_playctl_hand"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginLeft="50dp"
                android:layout_marginStart="50dp"
                skin:enable="true"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_play_control"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/rl_voice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <ImageView
                android:id="@+id/img_volumn_down"
                android:background="@drawable/remote_play_volumn_down"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerHorizontal="true"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/img_volumn_plus"
                android:background="@drawable/remote_play_volumn_plus"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginRight="100dp"
                android:layout_alignParentRight="true"
                android:layout_marginEnd="100dp"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/img_volumn_mute"
                android:background="@drawable/remote_btn_mute"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginLeft="100dp"
                android:layout_marginStart="100dp"
                skin:enable="true"/>
        </RelativeLayout>
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/img_poster"
            android:background="@drawable/default_poster_thumb"
            android:layout_width="250dp"
            android:layout_height="360dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            skin:enable="true"/>
        <TextView
            android:textSize="18sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_number"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginBottom="10dp"
            skin:enable="true"/>
        <RelativeLayout
            android:id="@+id/rl_play_control"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/img_play_pause"
                android:background="@drawable/remote_btn_pause"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_centerInParent="true"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/img_play_pre"
                android:background="@drawable/remote_play_previous"
                android:visibility="gone"
                android:layout_width="38dp"
                android:layout_height="40dp"
                android:layout_marginRight="50dp"
                android:layout_toLeftOf="@+id/img_play_pause"
                android:layout_centerVertical="true"
                android:layout_marginEnd="50dp"
                android:layout_toStartOf="@+id/img_play_pause"
                skin:enable="true"/>
            <ImageView
                android:id="@+id/img_play_next"
                android:background="@drawable/remote_play_next"
                android:visibility="gone"
                android:layout_width="38dp"
                android:layout_height="40dp"
                android:layout_marginLeft="50dp"
                android:layout_toRightOf="@+id/img_play_pause"
                android:layout_centerVertical="true"
                android:layout_marginStart="50dp"
                android:layout_toEndOf="@+id/img_play_pause"
                skin:enable="true"/>
        </RelativeLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_seekbar"
            android:paddingTop="30dp"
            android:paddingBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <SeekBar
                android:layout_gravity="center_horizontal"
                android:id="@+id/sb_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:layout_marginRight="30dp"
                android:maxHeight="2dp"
                android:max="100"
                android:progressDrawable="@drawable/remote_seekbar_style"
                android:minHeight="2dp"
                android:thumb="@drawable/remote_seekbar_thumb"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"/>
            <RelativeLayout
                android:layout_gravity="bottom"
                android:id="@+id/rl_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/remote_hinttext_textcolor"
                    android:id="@+id/tv_current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginStart="20dp"
                    skin:enable="true"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/remote_hinttext_textcolor"
                    android:id="@+id/tv_total_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_alignParentRight="true"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_alignParentEnd="true"
                    skin:enable="true"/>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
