<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:background="@color/scan_share_top"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <ImageView
            android:id="@+id/scan_share_image"
            android:layout_width="25dp"
            android:layout_height="50dp"
            android:src="@drawable/stb_pair_press"/>
        <TextView
            android:textSize="16dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/scan_share_btn_txt"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginLeft="10dp"
            android:text="@string/remote_scan"
            android:layout_toRightOf="@+id/scan_share_image"/>
    </LinearLayout>
</RelativeLayout>
