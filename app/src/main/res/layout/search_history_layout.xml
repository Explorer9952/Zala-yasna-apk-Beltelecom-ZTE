<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/search_history_layout"
    android:visibility="gone"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp">
    <RelativeLayout
        android:id="@+id/ll_search_history_text"
        android:background="@color/search_history_tab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true">
        <TextView
            android:textSize="14dp"
            android:textColor="@color/search_history_textcolor"
            android:layout_gravity="center_vertical"
            android:id="@+id/search_history_txt"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="18dp"
            android:layout_marginRight="18dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            skin:enable="true"/>
        <TextView
            android:textSize="14dp"
            android:textColor="@color/search_clearhistory_textcolor"
            android:layout_gravity="center_vertical"
            android:id="@+id/search_history_clear_all"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="18dp"
            android:layout_marginRight="18dp"
            android:layout_alignParentRight="true"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
    </RelativeLayout>
    <com.zte.iptvclient.android.common.customview.viewgroup.gridview.LineGridView
        android:id="@+id/search_history_lv"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:listSelector="@drawable/transparent"
        android:numColumns="1"
        android:divider="@color/search_history_grideviewdivide_bg"
        android:dividerHeight="0.5dp"
        skin:enable="true"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_search_history_clear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <View
            android:id="@+id/header_clear_line"
            android:background="@color/search_history_grideviewdivide_bg"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            skin:enable="true"/>
        <Button
            android:textSize="16sp"
            android:textColor="@color/search_select_textcolor"
            android:layout_gravity="center_horizontal"
            android:id="@+id/search_history_more_btn"
            android:background="@null"
            android:paddingLeft="25dp"
            android:paddingTop="5dp"
            android:paddingRight="20dp"
            android:paddingBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:paddingStart="25dp"
            android:paddingEnd="20dp"
            skin:enable="true"/>
        <View
            android:id="@+id/buttom_clear_line"
            android:background="@color/search_history_grideviewdivide_bg"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            skin:enable="true"/>
    </LinearLayout>
</LinearLayout>
