<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:layout_marginTop="5dp"
    android:layout_weight="1">
    <TextView
        android:textSize="16dp"
        android:textColor="@color/multiplayer_prevuename_future_light"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/txt_program"
        android:background="@color/multiplayer_seriesitem_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp"
        android:singleLine="true"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/img_close"
        android:background="@drawable/multiscreen_close_red"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:layout_alignParentEnd="true"
        skin:enable="true"/>
</RelativeLayout>
