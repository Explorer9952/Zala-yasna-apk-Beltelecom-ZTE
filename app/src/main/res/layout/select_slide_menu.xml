<?xml version="1.0" encoding="utf-8"?>
<com.zte.iptvclient.android.common.customview.viewgroup.layout.relativelayout.SquareLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/custom_menu_layout"
    android:background="@drawable/custom_menu_item_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/slide_menu_item_llayout"
        android:background="@drawable/slide_menu_selector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <ImageView
            android:id="@+id/slide_menu_item_img"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:scaleType="fitXY"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="normal"
            android:textColor="@drawable/slide_menu_txt_style"
            android:id="@+id/slide_menu_item_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</com.zte.iptvclient.android.common.customview.viewgroup.layout.relativelayout.SquareLayout>
