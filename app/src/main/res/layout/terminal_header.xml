<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:id="@+id/title_rlayout"
    android:layout_width="match_parent"
    android:layout_height="63dp">
    <Button
        android:gravity="center_vertical"
        android:id="@+id/terminal_btn_back"
        android:background="@drawable/title_back_bg"
        android:layout_width="43dp"
        android:layout_height="52dp"
        android:layout_centerVertical="true"
        skin:enable="true"/>
    <TextView
        android:textSize="23sp"
        android:textColor="@color/mine_favorite_title_textcolor"
        android:id="@+id/terminal_title_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        skin:enable="true"/>
    <ImageView
        android:id="@+id/terminal_header_bottom_line_one"
        android:background="@color/mine_favorite_separateline_bg"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_alignParentBottom="true"
        skin:enable="true"/>
</RelativeLayout>
