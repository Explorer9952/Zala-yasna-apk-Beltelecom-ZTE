<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include layout="@layout/detail_function_menu"/>
    <View
        android:id="@+id/tag_function_menu_line"
        android:background="@color/multiplayer_theme_dividerline_light"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        skin:enable="true"/>
    <include layout="@layout/tv_column_menu_layout"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channel_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="35dp"/>
        <View
            android:background="@color/multiplayer_date_selected_light"
            android:layout_width="0.5px"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"/>
    </RelativeLayout>
</LinearLayout>
