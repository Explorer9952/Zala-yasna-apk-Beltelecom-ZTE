<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/rl_tv_column_menu_layout"
    android:layout_width="match_parent"
    android:layout_height="45dp">
    <RelativeLayout
        android:orientation="horizontal"
        android:id="@+id/rl_viewmore"
        android:paddingTop="2dp"
        android:visibility="gone"
        android:layout_width="65dp"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:layout_marginEnd="5dp"
        android:layout_alignParentEnd="true"
        skin:enable="true">
        <ImageView
            android:id="@+id/view_more"
            android:background="@drawable/icon_sort_blue"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="5dp"
            android:layout_alignParentEnd="true"
            skin:enable="true"/>
        <TextView
            android:textSize="14dp"
            android:textColor="@color/tv_viewmore_text_textcolor"
            android:id="@+id/sort_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/view_more"
            skin:enable="true"/>
    </RelativeLayout>
    <com.zte.iptvclient.android.common.customview.viewgroup.scrollview.HorizontalScrollViewEx
        android:id="@+id/hs_column_view"
        android:paddingTop="@dimen/tv_channel_column_bg_shape_pading"
        android:paddingBottom="@dimen/tv_channel_column_bg_shape_pading"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@+id/rl_viewmore"/>
    <View
        android:id="@+id/tag_bottom_line"
        android:background="@color/multiplayer_theme_dividerline_light"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0.5px"
        android:layout_alignParentBottom="true"
        skin:enable="true"/>
</RelativeLayout>
