<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:background="@drawable/bg_pad"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    skin:enable="true">
    <TextView
        android:id="@+id/top"
        android:background="@color/tv_main_topstatus_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        skin:enable="true"/>
    <RelativeLayout
        android:id="@+id/ll_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_navbar_logo_and_search_total_height">
        <FrameLayout
            android:id="@+id/frame_top_navbar"
            android:layout_width="@dimen/top_navbar_search_layout_width"
            android:layout_height="@dimen/top_navbar_search_layout_height"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textSize="@dimen/top_navbar_title_textsize"
            android:textColor="@color/home_topnavbar_moresearch_textcolor"
            android:gravity="center"
            android:id="@+id/top_navbar_title_txt"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:maxLines="1"
            android:layout_marginStart="@dimen/top_navbar_title_margin_start"
            android:layout_toStartOf="@+id/frame_top_navbar"
            android:layout_alignParentStart="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/rl_tv_main_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <View
            android:id="@+id/guilde_line_horizontal_center"
            android:layout_width="0.1dp"
            android:layout_height="match_parent"
            android:layout_centerHorizontal="true"/>
        <View
            android:id="@+id/guilde_line_vertiacl_center"
            android:layout_width="match_parent"
            android:layout_height="0.1dp"
            android:layout_centerVertical="true"/>
        <FrameLayout
            android:id="@+id/tv_play_base_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignBottom="@+id/guilde_line_vertiacl_center"
            android:layout_alignEnd="@+id/guilde_line_horizontal_center"
            android:layout_alignParentStart="true"/>
        <FrameLayout
            android:id="@+id/tv_channel_list_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignTop="@+id/guilde_line_vertiacl_center"
            android:layout_alignEnd="@+id/guilde_line_horizontal_center"
            android:layout_alignParentStart="true"/>
        <FrameLayout
            android:id="@+id/tv_schedule_programes_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignStart="@+id/guilde_line_horizontal_center"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <View
        android:id="@+id/blank_view"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="@dimen/tv_hd_bottom_tabs_height"/>
</LinearLayout>
