<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    skin:enable="true">
    <ImageView
        android:id="@+id/iv_check"
        android:padding="5dp"
        android:visibility="invisible"
        android:layout_width="30dp"
        android:layout_height="wrap_content"
        android:src="@drawable/icon_select_white"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        android:layout_centerVertical="true"/>
    <TextView
        android:textSize="20dp"
        android:textColor="@color/video_popup_filter_txt_style"
        android:gravity="center"
        android:id="@+id/txt_filter"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:maxLines="1"
        android:singleLine="true"
        android:layout_toRightOf="@+id/iv_check"
        android:layout_toEndOf="@+id/iv_check"
        skin:enable="true"/>
</RelativeLayout>
