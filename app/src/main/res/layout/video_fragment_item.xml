<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:skin="http://schemas.android.com/android/skin"
    android:layout_gravity="center"
    android:id="@+id/home_video_item_fl"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/img_rlayout"
        android:layout_width="@dimen/dimen_vod_poster_thumb_width"
        android:layout_height="@dimen/dimen_vod_poster_thumb_height"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/poster_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/default_poster_thumb"
            android:scaleType="fitXY"
            skin:enable="true"/>
        <ImageView
            android:id="@+id/img_pay_free"
            android:visibility="gone"
            android:layout_width="@dimen/corner_width"
            android:layout_height="@dimen/corner_height"
            android:layout_alignParentTop="true"
            android:layout_alignParentRight="true"
            android:layout_alignParentEnd="true"/>
        <ImageView
            android:id="@+id/ivi_logo_top"
            android:visibility="gone"
            android:layout_width="27.2dp"
            android:layout_height="20dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/ivi_logo"
            android:layout_alignParentRight="true"/>
        <RelativeLayout
            android:id="@+id/rating_rl"
            android:background="@color/home_recommend_rating_bg"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_alignParentBottom="true"
            skin:enable="true">
            <TextView
                android:textSize="@dimen/common_title_bar_textsize"
                android:textColor="@color/vod_dark_textcolor"
                android:id="@+id/rating_txt"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:maxLines="1"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                skin:enable="true"/>
        </RelativeLayout>
    </RelativeLayout>
    <TextView
        android:textSize="@dimen/vod_detail_title_textsize"
        android:textColor="@color/home_video_title_textcolor"
        android:ellipsize="end"
        android:layout_gravity="bottom"
        android:id="@+id/title_txt"
        android:paddingLeft="3dp"
        android:visibility="visible"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="7dp"
        android:maxLines="1"
        android:paddingStart="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/img_rlayout"
        skin:enable="true"/>
</androidx.constraintlayout.widget.ConstraintLayout>
