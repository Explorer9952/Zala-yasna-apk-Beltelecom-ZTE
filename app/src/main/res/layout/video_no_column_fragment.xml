<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:skin="http://schemas.android.com/android/skin"
    android:orientation="vertical"
    android:id="@+id/ll_video_no_column_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/top"
        android:background="@color/transparent"
        style="@style/top_bar"
        skin:enable="true"/>
    <ViewStub
        android:id="@+id/view_stub_video"
        android:layout="@layout/viewstub_video"
        android:inflatedId="@+id/viewstub_video_id_after_inflate"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
