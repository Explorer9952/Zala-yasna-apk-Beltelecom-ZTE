<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/llayout_multi_play"
    android:padding="5dp"
    android:layout_width="wrap_content"
    android:layout_height="55dp">
    <RelativeLayout
        android:layout_gravity="center_vertical"
        android:id="@+id/rlayout_multi_play_container"
        android:background="@drawable/subcheck_bg"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:paddingStart="5dp"
        android:paddingEnd="5dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/black_old"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/txtvew_multi_play_channel_name"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="8dp"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"/>
        <ImageView
            android:id="@+id/ivew_multi_play_channel_delete"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="8dp"
            android:src="@drawable/channel_delete"
            android:layout_toRightOf="@+id/txtvew_multi_play_channel_name"
            android:layout_centerVertical="true"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="8dp"
            android:layout_toEndOf="@+id/txtvew_multi_play_channel_name"/>
    </RelativeLayout>
</LinearLayout>
